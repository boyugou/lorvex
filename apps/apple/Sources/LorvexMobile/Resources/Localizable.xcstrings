    "diagnostics.recent.empty": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Abstürze oder Hänger aufgezeichnet. Vom System erfasste Diagnosen erscheinen hier."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No crashes or hangs recorded. System-captured diagnostics appear here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se registraron fallos ni bloqueos. Los diagnósticos capturados por el sistema aparecen aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun plantage ou blocage enregistré. Les diagnostics capturés par le système apparaissent ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun arresto anomalo o blocco registrato. Le diagnostiche acquisite dal sistema appaiono qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クラッシュやハングは記録されていません。システムが取得した診断がここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기록된 충돌이나 멈춤이 없습니다. 시스템이 캡처한 진단이 여기에 표시됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie zarejestrowano awarii ani zawieszeń. Diagnostyki przechwycone przez system pojawią się tutaj."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma falha ou travamento registrado. Os diagnósticos capturados pelo sistema aparecem aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сбоев или зависаний не зафиксировано. Диагностика, собранная системой, появится здесь."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kayıtlı çökme veya takılma yok. Sistemin yakaladığı tanılamalar burada görünür."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未记录崩溃或卡顿。系统捕获的诊断信息将显示在此处。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未記錄當機或停頓。系統擷取的診斷資訊將顯示於此。"
          }
        }
      }
    },
    "diagnostics.recent.footer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abstürze, Hänger und Ressourcenausnahmen, die das System an Lorvex meldet, neueste zuerst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Crashes, hangs, and resource exceptions the system reports to Lorvex, newest first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fallos, bloqueos y excepciones de recursos que el sistema informa a Lorvex, primero los más recientes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Plantages, blocages et exceptions de ressources signalés par le système à Lorvex, les plus récents d’abord."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Arresti anomali, blocchi ed eccezioni di risorse che il sistema segnala a Lorvex, prima i più recenti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムが Lorvex に報告するクラッシュ、ハング、リソース例外を新しい順に表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템이 Lorvex에 보고하는 충돌, 멈춤 및 리소스 예외를 최신순으로 표시합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Awarie, zawieszenia i wyjątki zasobów zgłaszane przez system do Lorvex, od najnowszych."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Falhas, travamentos e exceções de recursos que o sistema relata ao Lorvex, os mais recentes primeiro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сбои, зависания и исключения ресурсов, о которых система сообщает Lorvex, начиная с новейших."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistemin Lorvex’e bildirdiği çökmeler, takılmalar ve kaynak istisnaları, en yeniden başlayarak."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统向 Lorvex 报告的崩溃、卡顿和资源异常，最新的排在前面。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "系統向 Lorvex 回報的當機、停頓和資源例外，最新的排在前面。"
          }
        }
      }
    },

    "calendar.create_event.description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Platziere einen echten Termin auf der Kalenderzeitleiste."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Place a real appointment on the calendar timeline."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloca una cita real en la línea de tiempo del calendario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Placez un vrai rendez-vous sur la chronologie du calendrier."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi un appuntamento reale sulla timeline del calendario."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カレンダーのタイムラインに実際の予定を追加します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캘린더 타임라인에 실제 일정을 추가합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Umieść prawdziwe wydarzenie na osi czasu kalendarza."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloque um compromisso real na linha do tempo do calendário."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте реальную встречу на шкалу календаря."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Takvim zaman çizelgesine gerçek bir randevu ekleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在日历时间轴上添加一个真实的日程。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在日曆時間軸上加入一個真實的行程。"
          }
        }
      }
    },

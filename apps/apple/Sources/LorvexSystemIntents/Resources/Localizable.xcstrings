    "system.task.update.description": {
      "comment": "Description for the Update Lorvex Task App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktualisiere Lorvex-Aufgabendetails über Kurzbefehle oder Siri."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Update Lorvex task details from Shortcuts or Siri."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualiza los detalles de una tarea de Lorvex desde Atajos o Siri."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettez à jour les détails d’une tâche Lorvex depuis Raccourcis ou Siri."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiorna i dettagli dell'attività Lorvex da Comandi rapidi o Siri."
          }

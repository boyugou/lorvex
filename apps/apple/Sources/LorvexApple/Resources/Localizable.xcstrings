    "calendar.timeline.load_error": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalenderereignisse konnten nicht geladen werden. Prüfe in den Systemeinstellungen, ob Lorvex Kalenderzugriff hat."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t load calendar events. Check that Lorvex has calendar access in System Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudieron cargar los eventos del calendario. Comprueba en Ajustes del Sistema que Lorvex tiene acceso al calendario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de charger les événements du calendrier. Vérifiez dans Réglages Système que Lorvex a accès au calendrier."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile caricare gli eventi del calendario. Verifica in Impostazioni di Sistema che Lorvex abbia accesso al calendario."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カレンダーのイベントを読み込めませんでした。システム設定で Lorvex にカレンダーへのアクセスが許可されているか確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캘린더 일정을 불러올 수 없습니다. 시스템 설정에서 Lorvex에 캘린더 접근 권한이 있는지 확인하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się wczytać wydarzeń kalendarza. Sprawdź w Ustawieniach systemowych, czy Lorvex ma dostęp do kalendarza."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível carregar os eventos do calendário. Verifica nas Definições do Sistema se o Lorvex tem acesso ao calendário."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось загрузить события календаря. Проверьте в системных настройках, есть ли у Lorvex доступ к календарю."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Takvim etkinlikleri yüklenemedi. Sistem Ayarları’ndan Lorvex’in takvim erişimi olduğundan emin olun."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法加载日历事件。请在“系统设置”中确认 Lorvex 拥有日历访问权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法載入日曆事件。請在「系統設定」中確認 Lorvex 擁有日曆存取權限。"
          }
        }
      }
    },

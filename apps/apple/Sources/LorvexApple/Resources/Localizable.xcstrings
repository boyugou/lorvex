          "stringUnit": {
            "state": "translated",
            "value": "Los eventos recurrentes y de varios días no se pueden arrastrar ni redimensionar en la cuadrícula del calendario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les événements récurrents et sur plusieurs jours ne peuvent pas être déplacés ni redimensionnés dans la grille du calendrier."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli eventi ricorrenti e su più giorni non possono essere trascinati o ridimensionati nella griglia del calendario."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "繰り返しや複数日のイベントはカレンダーグリッドでドラッグやサイズ変更ができません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "반복 및 여러 날에 걸친 이벤트는 캘린더 그리드에서 드래그하거나 크기를 조절할 수 없습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wydarzeń powtarzających się i wielodniowych nie można przeciągać ani zmieniać ich rozmiaru w siatce kalendarza."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Eventos recorrentes e de vários dias não podem ser arrastados nem redimensionados na grade do calendário."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повторяющиеся и многодневные события нельзя перетаскивать или изменять их размер в сетке календаря."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yinelenen ve çok günlü etkinlikler takvim ızgarasında sürüklenemez veya yeniden boyutlandırılamaz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重复和跨天日程无法在日历网格中拖动或调整大小。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "重複和跨天行程無法在日曆格線中拖曳或調整大小。"
          }
        }
      }
    },
    "calendar.weekgrid.edit_hint.help": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Termin-Editor öffnen, um Wiederholungen oder mehrtägige Details zu bearbeiten"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open the event sheet to edit recurring or multi-day details"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre el editor del evento para editar detalles recurrentes o de varios días"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrir l'éditeur de l'événement pour modifier les détails récurrents ou sur plusieurs jours"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri l'editor dell'evento per modificare i dettagli ricorrenti o su più giorni"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "繰り返しや複数日の詳細を編集するにはイベントエディタを開いてください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "반복 또는 여러 날에 걸친 세부 정보를 편집하려면 이벤트 편집기를 여세요"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Otwórz edytor wydarzenia, aby edytować szczegóły powtarzające się lub wielodniowe"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra o editor do evento para editar detalhes recorrentes ou de vários dias"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте редактор события, чтобы изменить повторяющиеся или многодневные параметры"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yinelenen veya çok günlü ayrıntıları düzenlemek için etkinlik düzenleyiciyi açın"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开日程编辑器以编辑重复或跨天详情"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟行程編輯器以編輯重複或跨天詳細資訊"
          }
        }
      }
    },

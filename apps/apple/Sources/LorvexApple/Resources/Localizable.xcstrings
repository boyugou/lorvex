    "database.recovery.notice": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex konnte deine vorherige Datenbank (%1$@) nicht öffnen. Sie wurde daher unter %2$@ beiseitegelegt und eine neue wurde erstellt. Deine früheren Daten bleiben dort erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex couldn't open your previous database (%1$@), so it was set aside at %2$@ and a fresh one was created. Your earlier data is preserved there."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex no pudo abrir tu base de datos anterior (%1$@), así que se apartó en %2$@ y se creó una nueva. Tus datos anteriores se conservan allí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex n'a pas pu ouvrir votre base de données précédente (%1$@) ; elle a donc été mise de côté dans %2$@ et une nouvelle a été créée. Vos anciennes données y sont conservées."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex non è riuscito ad aprire il tuo database precedente (%1$@), quindi è stato messo da parte in %2$@ ed è stato creato uno nuovo. I tuoi dati precedenti sono conservati lì."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex は以前のデータベース（%1$@）を開けなかったため、%2$@ に退避し、新しいデータベースを作成しました。以前のデータはそこに保存されています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex가 이전 데이터베이스(%1$@)를 열지 못해 %2$@ 위치에 따로 보관하고 새 데이터베이스를 만들었습니다. 이전 데이터는 그곳에 보존되어 있습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex nie mógł otworzyć poprzedniej bazy danych (%1$@), więc została ona odłożona w %2$@ i utworzono nową. Twoje wcześniejsze dane są tam zachowane."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lorvex não conseguiu abrir seu banco de dados anterior (%1$@), então ele foi reservado em %2$@ e um novo foi criado. Seus dados anteriores estão preservados lá."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex не смог открыть вашу предыдущую базу данных (%1$@), поэтому она была отложена в %2$@, а новая создана. Ваши прежние данные сохранены там."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex önceki veritabanınızı (%1$@) açamadı; bu yüzden %2$@ konumunda bir kenara alındı ve yenisi oluşturuldu. Önceki verileriniz orada korunuyor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 无法打开你之前的数据库（%1$@），因此已将其保存在 %2$@ 并创建了一个新数据库。你之前的数据仍保留在那里。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 無法開啟你先前的資料庫（%1$@），因此已將其保存在 %2$@ 並建立了一個新資料庫。你先前的資料仍保留在那裡。"
          }
        }
      }
    },

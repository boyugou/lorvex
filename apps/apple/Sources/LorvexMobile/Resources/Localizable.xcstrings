          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "使用できる iCloud アカウントがありません。iCloud にサインインしてからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용할 수 있는 iCloud 계정이 없습니다. iCloud에 로그인한 후 다시 시도하십시오."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Brak dostępnego konta iCloud. Zaloguj się do iCloud i spróbuj ponownie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma conta do iCloud utilizável. Inicie sessão no iCloud e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет доступной учётной записи iCloud. Войдите в iCloud и попробуйте ещё раз."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kullanılabilir bir iCloud hesabı yok. iCloud’da oturum açıp yeniden deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有可用的 iCloud 账户。请登录 iCloud 后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "沒有可用的 iCloud 帳號。請登入 iCloud 後再試一次。"

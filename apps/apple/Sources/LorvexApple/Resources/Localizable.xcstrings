    "task.permanent_delete.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Aufgabe und alle ihre Checklistenpunkte, Erinnerungen und Verknüpfungen werden endgültig entfernt. Das lässt sich nicht rückgängig machen – mit „Abbrechen“ bleibt der Eintrag erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This task and all its checklist items, reminders, and links are removed for good. This can't be undone — use Cancel to keep the record instead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta tarea y todos sus elementos de lista, recordatorios y vínculos se eliminan para siempre. No se puede deshacer; usa Cancelar para conservar el registro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette tâche et tous ses éléments de liste, rappels et liens sont supprimés définitivement. Action irréversible — utilisez Annuler pour conserver l’enregistrement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa attività e tutti i suoi elementi di elenco, promemoria e collegamenti vengono rimossi per sempre. Operazione irreversibile: usa Annulla per conservare il record."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このタスクとそのチェックリスト項目、リマインダー、リンクがすべて完全に削除されます。元に戻せません。記録を残すにはキャンセルしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 작업과 모든 체크리스트 항목, 알림, 링크가 영구히 제거됩니다. 되돌릴 수 없습니다. 기록을 남기려면 취소를 사용하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To zadanie oraz wszystkie jego pozycje listy, przypomnienia i powiązania zostaną trwale usunięte. Nie można tego cofnąć — użyj Anuluj, aby zachować wpis."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta tarefa e todos os seus itens de lista, lembretes e ligações são removidos para sempre. Não pode ser desfeito — use Cancelar para manter o registo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта задача и все её пункты списка, напоминания и связи будут удалены навсегда. Отменить нельзя — нажмите «Отмена», чтобы сохранить запись."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu görev ve tüm kontrol listesi öğeleri, hatırlatıcıları ve bağlantıları kalıcı olarak kaldırılır. Geri alınamaz — kaydı tutmak için İptal'i kullanın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此任务及其所有清单项、提醒和关联都将被永久删除，无法撤销。如需保留记录，请改用“取消”。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此任務及其所有清單項目、提醒和關聯都會被永久刪除，無法復原。若要保留記錄，請改用「取消」。"
          }
        }
      }
    },

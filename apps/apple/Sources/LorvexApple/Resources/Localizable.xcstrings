    "settings.permissions.badge_footer": {
      "comment": "Footer explaining the Dock badge task count",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigt die Anzahl überfälliger und heute fälliger offener Aufgaben auf dem Dock-Symbol an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows the number of overdue and due-today open tasks on the Dock icon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra en el icono del Dock el número de tareas pendientes vencidas y que vencen hoy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche sur l'icône du Dock le nombre de tâches en cours en retard et dues aujourd'hui."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra sull'icona del Dock il numero di attività aperte in ritardo e in scadenza oggi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "期限切れと今日が期限の未完了タスクの件数を Dock アイコンに表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기한이 지났거나 오늘 마감인 미완료 작업 수를 Dock 아이콘에 표시합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokazuje liczbę zaległych i dziś przypadających otwartych zadań na ikonie w Docku."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra no ícone do Dock o número de tarefas pendentes atrasadas e com vencimento hoje."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показывает количество просроченных и сегодняшних открытых задач на значке в Dock."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dock simgesinde gecikmiş ve bugün zamanı gelen açık görev sayısını gösterir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Dock 图标上显示逾期和今日到期的未完成任务数量。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Dock 圖示上顯示逾期和今日到期的未完成任務數量。"
          }
        }
      }
    },

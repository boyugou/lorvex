    "system.focus.schedule.parameter.rationale.description": {
      "comment": "Parameter description for an optional focus schedule save rationale",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optionale Notiz, die erklärt, warum dieser Zeitplan gespeichert wurde."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional note explaining why this schedule was saved."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nota opcional que explica por qué se guardó este horario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Note facultative expliquant pourquoi cet horaire a été enregistré."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nota opzionale che spiega perché questo programma è stato salvato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このスケジュールを保存した理由を説明する任意のメモ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 일정을 저장한 이유를 설명하는 선택적 메모."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opcjonalna notatka wyjaśniająca, dlaczego zapisano ten harmonogram."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nota opcional explicando por que esta agenda foi salva."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Необязательная заметка с объяснением, почему это расписание сохранено."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu zamanlamanın neden kaydedildiğini açıklayan isteğe bağlı not."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选备注，说明为什么保存此日程。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "可選備註，說明為什麼儲存此日程。"
          }
        }
      }
    },
    "system.focus.schedule.propose.description": {
      "comment": "Description for the Propose Lorvex Focus Schedule App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einen Lorvex-Fokusplan für heute oder ein bestimmtes Datum vorschlagen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Propose a Lorvex focus schedule for today or a specific date."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Propón una programación de enfoque de Lorvex para hoy o una fecha específica."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Proposer un planning de concentration Lorvex pour aujourd'hui ou une date précise."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Proponi un programma di focus Lorvex per oggi o una data specifica."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日または特定の日付の Lorvex フォーカススケジュールを提案します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘 또는 특정 날짜의 Lorvex 집중 일정을 제안합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaproponuj harmonogram skupienia Lorvex na dziś lub konkretną datę."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Propõe uma agenda de foco do Lorvex para hoje ou uma data específica."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Предложение расписания фокуса Lorvex на сегодня или конкретную дату."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bugün veya belirli bir tarih için bir Lorvex odak zamanlaması öner."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为今天或指定日期生成 Lorvex 专注日程建议。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為今天或指定日期產生 Lorvex 專注日程建議。"
          }
        }
      }
    },

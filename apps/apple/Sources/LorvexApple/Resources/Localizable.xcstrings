    "settings.cloud_sync.resume.confirm.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex lädt die auf diesem Mac gespeicherten Daten in den aktuell angemeldeten iCloud-Account hoch und setzt die Synchronisierung fort."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex will upload the data stored on this Mac to the currently signed-in iCloud account and resume syncing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex subirá los datos guardados en este Mac a la cuenta de iCloud con la sesión iniciada actualmente y reanudará la sincronización."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex téléversera les données stockées sur ce Mac vers le compte iCloud actuellement connecté et reprendra la synchronisation."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex caricherà i dati archiviati su questo Mac nell’account iCloud attualmente connesso e riprenderà la sincronizzazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex はこの Mac に保存されているデータを、現在サインイン中の iCloud アカウントにアップロードして同期を再開します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex가 이 Mac에 저장된 데이터를 현재 로그인된 iCloud 계정으로 업로드하고 동기화를 재개합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex prześle dane zapisane na tym Macu do aktualnie zalogowanego konta iCloud i wznowi synchronizację."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lorvex enviará os dados armazenados neste Mac para a conta do iCloud com sessão iniciada no momento e retomará a sincronização."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex загрузит данные, хранящиеся на этом Mac, в текущую учётную запись iCloud и возобновит синхронизацию."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex, bu Mac’te saklanan verileri şu anda oturum açılmış iCloud hesabına yükleyip eşitlemeyi sürdürecek."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 会将这台 Mac 上存储的数据上传到当前登录的 iCloud 账户，并恢复同步。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 會將這台 Mac 上儲存的資料上傳到目前登入的 iCloud 帳號，並恢復同步。"
          }
        }
      }
    },
    "settings.cloud_sync.resume.confirm.title": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Daten dieses Mac erneut hochladen und Synchronisierung fortsetzen?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Re-upload this Mac’s data and resume sync?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Volver a subir los datos de este Mac y reanudar la sincronización?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Téléverser à nouveau les données de ce Mac et reprendre la synchronisation ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricaricare i dati di questo Mac e riprendere la sincronizzazione?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この Mac のデータを再アップロードして同期を再開しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 Mac의 데이터를 다시 업로드하고 동기화를 재개하시겠습니까?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przesłać ponownie dane z tego Maca i wznowić synchronizację?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Reenviar os dados deste Mac e retomar a sincronização?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Загрузить данные этого Mac заново и возобновить синхронизацию?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu Mac’in verileri yeniden yüklensin ve eşitleme sürdürülsün mü?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要重新上传这台 Mac 的数据并恢复同步吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "要重新上傳這台 Mac 的資料並恢復同步嗎？"
          }
        }
      }
    },

    "settings.data_import.preview.not_imported": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht importiert (noch nicht sicher wiederherstellbar)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not imported (can't be safely restored yet)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No importado (todavía no se puede restaurar de forma segura)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Non importé (pas encore restaurable en toute sécurité)"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non importato (non ancora ripristinabile in sicurezza)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未インポート（まだ安全に復元できません）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가져오지 않음(아직 안전하게 복원할 수 없음)"
          }

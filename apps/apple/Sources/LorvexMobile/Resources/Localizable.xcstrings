    "tasks.empty.someday.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Irgendwann“-Aufgaben sind geparkte Vorhaben, die heute nicht ablenken sollten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Someday tasks are parked commitments that should not distract today."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las tareas «Algún día» son compromisos en espera que no deberían distraerte hoy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les tâches « Un jour » sont des engagements mis de côté qui ne devraient pas vous distraire aujourd'hui."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le attività Someday sono impegni parcheggiati che non dovrebbero distrarre oggi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「いつか」のタスクは保留中の予定であり、今日の集中を妨げるべきではありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "「언젠가」 작업은 보류된 약속으로, 오늘 주의를 분산시켜서는 안 됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadania „Kiedyś” to odłożone zobowiązania, które nie powinny dziś rozpraszać."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As tarefas \"Algum dia\" são compromissos guardados que não devem distrair você hoje."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Задачи «Когда-нибудь» — это отложенные обязательства, которые не должны отвлекать сегодня."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir gün görevleri, bugün dikkat dağıtmaması gereken park edilmiş taahhütlerdir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Someday 任务是暂存的承诺，不应干扰今天。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「將來某天」任務是暫存的承諾，不應干擾今天。"
          }
        }
      }
    },

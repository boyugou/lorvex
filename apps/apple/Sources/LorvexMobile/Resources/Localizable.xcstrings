    "recurring_cancel.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur dieses Vorkommen abbrechen oder die gesamte Serie beenden?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel only this occurrence, or end the whole repeating series?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cancelar solo esta repetición o finalizar toda la serie?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Annuler uniquement cette occurrence ou mettre fin à toute la série ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Annullare solo questa occorrenza o terminare l'intera serie ricorrente?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この繰り返しのみキャンセルしますか、それとも繰り返し全体を終了しますか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 반복만 취소하시겠습니까, 아니면 전체 반복 시리즈를 종료하시겠습니까?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Anulować tylko to wystąpienie, czy zakończyć całą powtarzającą się serię?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancelar apenas esta ocorrência ou encerrar toda a série recorrente?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отменить только это повторение или завершить всю серию повторений?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca bu tekrar mı iptal edilsin, yoksa tüm yinelenen seri mi sonlandırılsın?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只取消这一次，还是结束整个重复系列？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "只取消這一次，還是結束整個重複系列？"
          }
        }
      }
    },

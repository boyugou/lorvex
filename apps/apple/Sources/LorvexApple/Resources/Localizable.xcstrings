    "settings.cloud_sync.account.no_account_message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein iCloud-Konto. Melde dich über „Systemeinstellungen“ > „Apple-Account“ an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No iCloud account. Sign in via System Settings > Apple Account."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay cuenta de iCloud. Inicia sesión en Ajustes del Sistema > Cuenta de Apple."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun compte iCloud. Connectez-vous via Réglages Système > Compte Apple."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun account iCloud. Accedi tramite Impostazioni di Sistema > Account Apple."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud アカウントがありません。「システム設定」>「Apple アカウント」からサインインしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 계정이 없습니다. 시스템 설정 > Apple 계정에서 로그인하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",

    "calendar.week.unauthorized.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on Calendar access in System Settings to see your events here."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiviere den Kalenderzugriff in den Systemeinstellungen, um deine Termine hier zu sehen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa el acceso al calendario en Ajustes del Sistema para ver tus eventos aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez l'accès au calendrier dans Réglages Système pour voir vos événements ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attiva l'accesso al calendario in Impostazioni di Sistema per vedere qui i tuoi eventi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システム設定でカレンダーへのアクセスをオンにすると、ここに予定が表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여기에 일정을 표시하려면 시스템 설정에서 캘린더 접근을 켜세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Włącz dostęp do kalendarza w Ustawieniach systemowych, aby zobaczyć tu swoje wydarzenia."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative o acesso ao calendário em Ajustes do Sistema para ver seus eventos aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включите доступ к календарю в Системных настройках, чтобы видеть события здесь."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Etkinliklerinizi burada görmek için Sistem Ayarları'ndan Takvim erişimini açın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在系统设置中开启日历访问权限即可在此查看你的事件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在系統設定中開啟日曆存取權限即可在此查看你的事件。"
          }
        }
      }
    },

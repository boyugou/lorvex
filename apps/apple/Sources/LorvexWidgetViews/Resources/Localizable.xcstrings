    "widget.action.defer.a11y": {
      "comment": "Accessibility label for the defer-task widget button; %@ is the task title",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ auf morgen verschieben"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Defer %@ until tomorrow"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Posponer %@ hasta mañana"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reporter %@ à demain"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rinvia %@ a domani"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」を明日まで延期"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@을(를) 내일로 미루기"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odrocz %@ na jutro"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adiar %@ para amanhã"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отложить %@ до завтра"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ öğesini yarına ertele"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将“%@”推迟到明天"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將「%@」延後到明天"
          }
        }
      }
    },

    "settings.calendar.sync_error_friendly": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Kalendersynchronisierung wurde nicht abgeschlossen. Prüfe in den Systemeinstellungen, ob Lorvex Kalenderzugriff hat, und versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calendar sync didn’t finish. Check that Lorvex has calendar access in System Settings, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La sincronización del calendario no terminó. Comprueba en Ajustes del Sistema que Lorvex tiene acceso al calendario e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La synchronisation du calendrier ne s’est pas terminée. Vérifiez dans Réglages Système que Lorvex a accès au calendrier, puis réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La sincronizzazione del calendario non è stata completata. Verifica in Impostazioni di Sistema che Lorvex abbia accesso al calendario e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カレンダーの同期が完了しませんでした。システム設定で Lorvex にカレンダーへのアクセスが許可されているか確認して、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캘린더 동기화가 완료되지 않았습니다. 시스템 설정에서 Lorvex에 캘린더 접근 권한이 있는지 확인한 후 다시 시도하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchronizacja kalendarza nie zakończyła się. Sprawdź w Ustawieniach systemowych, czy Lorvex ma dostęp do kalendarza, i spróbuj ponownie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A sincronização do calendário não terminou. Verifica nas Definições do Sistema se o Lorvex tem acesso ao calendário e tenta novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Синхронизация календаря не завершилась. Проверьте в системных настройках, есть ли у Lorvex доступ к календарю, и повторите попытку."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Takvim eşitlemesi tamamlanmadı. Sistem Ayarları’ndan Lorvex’in takvim erişimi olduğundan emin olun ve yeniden deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "日历同步未完成。请在“系统设置”中确认 Lorvex 拥有日历访问权限，然后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "日曆同步未完成。請在「系統設定」中確認 Lorvex 擁有日曆存取權限，然後重試。"
          }
        }
      }
    },
    "settings.calendar.two_way_detail": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Liest deine Kalenderereignisse in Lorvex ein und schreibt von Lorvex geplante Blöcke in einen eigenen Kalender „Lorvex“ – niemals in deine persönlichen Kalender."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read your calendar events into Lorvex and write Lorvex-scheduled blocks into a dedicated \"Lorvex\" calendar — never your personal calendars."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee tus eventos de calendario en Lorvex y escribe los bloques programados por Lorvex en un calendario dedicado «Lorvex», nunca en tus calendarios personales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lit vos événements de calendrier dans Lorvex et écrit les blocs planifiés par Lorvex dans un calendrier dédié « Lorvex » — jamais dans vos calendriers personnels."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Leggi i tuoi eventi di calendario in Lorvex e scrivi i blocchi pianificati da Lorvex in un calendario \"Lorvex\" dedicato — mai nei tuoi calendari personali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カレンダーのイベントをLorvexに読み込み、Lorvexがスケジュールしたブロックを専用の「Lorvex」カレンダーに書き込みます。個人のカレンダーには決して書き込みません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캘린더 이벤트를 Lorvex로 읽어 들이고 Lorvex가 예약한 블록을 전용 \"Lorvex\" 캘린더에 기록합니다. 개인 캘린더에는 절대 기록하지 않습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odczytaj wydarzenia z kalendarza do Lorvex i zapisuj bloki zaplanowane przez Lorvex do dedykowanego kalendarza „Lorvex” — nigdy do osobistych kalendarzy."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Lê os eventos do seu calendário no Lorvex e grava os blocos agendados pelo Lorvex em um calendário dedicado \"Lorvex\" — nunca nos seus calendários pessoais."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Читает события вашего календаря в Lorvex и записывает запланированные Lorvex блоки в отдельный календарь «Lorvex» — никогда в ваши личные календари."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Takvim etkinliklerinizi Lorvex'e okuyun ve Lorvex tarafından zamanlanan blokları kişisel takvimlerinize değil, özel bir \"Lorvex\" takvimine yazın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将你的日历事件读入 Lorvex，并把 Lorvex 排期块写入专用的“Lorvex”日历，不会写入你的个人日历。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將你的行事曆事件讀入 Lorvex，並把 Lorvex 排程的時段寫入專用的「Lorvex」行事曆，不會寫入你的個人行事曆。"
          }
        }
      }
    },

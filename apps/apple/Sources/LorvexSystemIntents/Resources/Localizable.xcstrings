          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%2$@의 캘린더 이벤트 %1$@을(를) 생성했습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Utworzono wydarzenie w kalendarzu %@ dla %@."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Evento de calendário %@ criado para %@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создано событие календаря %@ для %@."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ için %@ takvim etkinliği oluşturuldu."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已为 %2$@ 创建日历事件“%1$@”。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已為 %2$@ 建立行事曆事件「%1$@」。"
          }
        }
      }
    },

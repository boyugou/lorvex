    "error.database_newer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Datenbank wurde mit einer neueren Version von Lorvex erstellt. Bitte aktualisiere Lorvex, um sie zu öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This database was created by a newer version of Lorvex. Please update Lorvex to open it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta base de datos se creó con una versión más reciente de Lorvex. Actualiza Lorvex para abrirla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette base de données a été créée par une version plus récente de Lorvex. Veuillez mettre à jour Lorvex pour l'ouvrir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo database è stato creato da una versione più recente di Lorvex. Aggiorna Lorvex per aprirlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデータベースは新しいバージョンの Lorvex で作成されました。開くには Lorvex を更新してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 데이터베이스는 최신 버전의 Lorvex에서 생성되었습니다. 열려면 Lorvex를 업데이트해 주세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta baza danych została utworzona przez nowszą wersję Lorvex. Zaktualizuj Lorvex, aby ją otworzyć."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este banco de dados foi criado por uma versão mais recente do Lorvex. Atualize o Lorvex para abri-lo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта база данных создана более новой версией Lorvex. Пожалуйста, обновите Lorvex, чтобы открыть её."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu veritabanı Lorvex'in daha yeni bir sürümü tarafından oluşturuldu. Açmak için lütfen Lorvex'i güncelleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此数据库由较新版本的 Lorvex 创建。请更新 Lorvex 以打开它。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此資料庫由較新版本的 Lorvex 建立。請更新 Lorvex 以開啟它。"
          }
        }
      }
    },
    "error.storage_unavailable": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex kann nicht auf seinen Datenspeicher zugreifen, daher konnte dies nicht abgeschlossen werden. Bitte starte Lorvex neu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex can't access its data storage, so this couldn't be completed. Please restart Lorvex."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex no puede acceder a su almacenamiento de datos, por lo que no se pudo completar. Reinicia Lorvex."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex ne peut pas accéder à son stockage de données, l'opération n'a donc pas pu être effectuée. Veuillez redémarrer Lorvex."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex non riesce ad accedere all'archivio dati, quindi l'operazione non è stata completata. Riavvia Lorvex."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex がデータストレージにアクセスできないため、この操作を完了できませんでした。Lorvex を再起動してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex가 데이터 저장소에 접근할 수 없어 작업을 완료하지 못했습니다. Lorvex를 다시 시작해 주세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex nie może uzyskać dostępu do swojego magazynu danych, więc nie udało się tego ukończyć. Uruchom ponownie Lorvex."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lorvex não consegue acessar seu armazenamento de dados, então não foi possível concluir. Reinicie o Lorvex."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex не может получить доступ к своему хранилищу данных, поэтому действие не удалось выполнить. Пожалуйста, перезапустите Lorvex."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex veri deposuna erişemiyor, bu yüzden bu işlem tamamlanamadı. Lütfen Lorvex'i yeniden başlatın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 无法访问其数据存储，因此无法完成此操作。请重新启动 Lorvex。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 無法存取其資料儲存空間，因此無法完成此操作。請重新啟動 Lorvex。"
          }
        }
      }
    },

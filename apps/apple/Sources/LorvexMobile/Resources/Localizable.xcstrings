    "tasks.empty.message": {
      "comment": "Empty-state description when there are no open tasks",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfasse eine Aufgabe, um loszulegen – oder bitte deinen KI-Assistenten, deinen Tag zu planen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture a task to get started — or ask your AI assistant to plan your day."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Captura una tarea para empezar, o pide a tu asistente de IA que planifique tu día."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Capturez une tâche pour commencer, ou demandez à votre assistant IA de planifier votre journée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cattura un'attività per iniziare — o chiedi al tuo assistente IA di pianificare la giornata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タスクをキャプチャして始めましょう。あるいは AI アシスタントに 1 日の計画を立ててもらいましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작업을 캡처해 시작하거나, AI 어시스턴트에게 하루 계획을 세워 달라고 요청하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przechwyć zadanie, aby zacząć — albo poproś asystenta AI o zaplanowanie dnia."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture uma tarefa para começar — ou peça ao seu assistente de IA para planejar o seu dia."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Захватите задачу, чтобы начать, — или попросите ИИ-ассистента спланировать ваш день."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Başlamak için bir görev yakalayın — ya da AI asistanınızdan gününüzü planlamasını isteyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "捕捉一个任务即可开始——或让你的 AI 助手为你规划这一天。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "擷取一個任務即可開始——或請你的 AI 助理為你規劃這一天。"
          }
        }
      }
    },
    "tasks.empty.open.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfasse eine Aufgabe oder bitte den Assistenten, die nächste sinnvolle Arbeit zu planen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture a task or ask the assistant to plan the next useful work."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Captura una tarea o pide al asistente que planifique el siguiente trabajo útil."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Capturez une tâche ou demandez à l'assistant de planifier le prochain travail utile."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cattura un'attività o chiedi all'assistente di pianificare il prossimo lavoro utile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タスクをキャプチャするか、アシスタントに次に取り組むべき有用な作業を計画してもらいましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작업을 캡처하거나 어시스턴트에게 다음에 할 유용한 작업을 계획해 달라고 요청하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przechwyć zadanie lub poproś asystenta o zaplanowanie kolejnej przydatnej pracy."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture uma tarefa ou peça ao assistente para planejar o próximo trabalho útil."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Захватите задачу или попросите ассистента спланировать следующую полезную работу."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir görev yakalayın veya asistandan bir sonraki yararlı işi planlamasını isteyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "捕捉一个任务，或让助手规划下一件有价值的事。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "擷取一個任務，或請助理規劃下一件有價值的工作。"
          }
        }
      }
    },

    "system.diagnostics.read.description": {
      "comment": "Description for the Read Lorvex Diagnostics App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex-Einrichtungs- und Synchronisierungsdiagnose über Kurzbefehle oder Siri lesen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read Lorvex setup and sync diagnostics from Shortcuts or Siri."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee los diagnósticos de configuración y sincronización de Lorvex desde Atajos o Siri."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lire les diagnostics de configuration et de synchronisation Lorvex depuis Raccourcis ou Siri."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Leggi la diagnostica di configurazione e sincronizzazione Lorvex da Comandi rapidi o Siri."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットまたは Siri から Lorvex のセットアップと同期の診断を読み取ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축어 또는 Siri에서 Lorvex 설정 및 동기화 진단을 읽습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odczytaj diagnostykę konfiguracji i synchronizacji Lorvex ze Skrótów lub Siri."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Lê os diagnósticos de configuração e sincronização do Lorvex pelos Atalhos ou pela Siri."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чтение диагностики настройки и синхронизации Lorvex из «Быстрых команд» или Siri."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısayollar veya Siri ile Lorvex kurulum ve eşitleme tanılamalarını oku."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从“快捷指令”或 Siri 读取 Lorvex 设置和同步诊断。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從「捷徑」或 Siri 讀取 Lorvex 設定和同步診斷。"
          }
        }
      }
    },
    "system.diagnostics.read.dialog.complete": {
      "comment": "Diagnostics dialog when setup is complete; arguments are backend, pending count, and failed count",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Lorvex-Einrichtung ist abgeschlossen. Sync-Backend: %1$@. Ausstehend: %2$lld, fehlgeschlagen: %3$lld."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex setup is complete. Sync backend: %1$@. Pending: %2$lld, failed: %3$lld."
          }
        },
        "es": {

    "system.focus.current.clear.description": {
      "comment": "Description for the Clear Lorvex Current Focus App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lösche den Lorvex-Fokusplan für heute oder ein bestimmtes Datum über Kurzbefehle oder Siri."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear the Lorvex focus plan for today or a specific date from Shortcuts or Siri."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Borra el plan de enfoque de Lorvex para hoy o una fecha concreta desde Atajos o Siri."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Effacez le plan de concentration Lorvex pour aujourd'hui ou une date précise depuis Raccourcis ou Siri."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancella il piano di focus Lorvex per oggi o una data specifica da Comandi rapidi o Siri."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットや Siri から、今日または指定した日付の Lorvex フォーカスプランをクリアします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축어나 Siri에서 오늘 또는 특정 날짜의 Lorvex 집중 계획을 지웁니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyczyść plan skupienia Lorvex na dziś lub konkretną datę ze Skrótów lub Siri."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpe o plano de foco do Lorvex para hoje ou uma data específica a partir dos Atalhos ou da Siri."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистите план фокусировки Lorvex на сегодня или конкретную дату через «Быстрые команды» или Siri."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısayollar veya Siri ile bugünün veya belirli bir tarihin Lorvex odak planını temizle."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从“快捷指令”或 Siri 清空今天或指定日期的 Lorvex 专注计划。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從「捷徑」或 Siri 清空今天或指定日期的 Lorvex 專注計畫。"
          }
        }
      }
    },

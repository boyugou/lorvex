    "review.empty.not_loaded.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wochenmuster erscheinen, sobald Lorvex genug aktuelle Aufgabenaktivität zusammenfassen kann."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Weekly patterns appear after Lorvex has enough recent task activity to summarize."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los patrones semanales aparecen cuando Lorvex tiene suficiente actividad reciente de tareas para resumir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les tendances hebdomadaires apparaissent lorsque Lorvex a assez d’activité récente à résumer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I pattern settimanali appaiono quando Lorvex ha abbastanza attività recente da riassumere."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex が要約できるだけの最近のタスク活動を取得すると、週次パターンが表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex가 요약할 최근 작업 활동을 충분히 확보하면 주간 패턴이 표시됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wzorce tygodniowe pojawią się, gdy Lorvex będzie mieć dość ostatniej aktywności zadań do podsumowania."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Padrões semanais aparecem quando o Lorvex tem atividade recente suficiente para resumir."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Недельные закономерности появятся, когда у Lorvex будет достаточно недавней активности задач для сводки."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex özetlemek için yeterli yeni görev etkinliğine sahip olduğunda haftalık kalıplar görünür."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当 Lorvex 有足够近期任务活动可总结时，每周模式会显示。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當 Lorvex 有足夠近期任務活動可摘要時，每週模式會顯示。"
          }
        }
      }
    },

    "habits.field.encouragement.footer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine motivierende Zeile, die du beim Gewohnheitseintrag siehst – z. B. „Lies 30 Minuten und dein Geist wird reicher.“"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A motivating line you’ll see on the habit — e.g. “Read 30 minutes and your mind grows richer.”"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una frase motivadora que verás en el hábito — p. ej. «Lee 30 minutos y tu mente crece más»."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une phrase motivante que vous verrez sur l’habitude — p. ex. « Lisez 30 minutes et votre esprit grandit »."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una frase motivante che vedrai sull’abitudine — es. «Leggi 30 minuti e la tua mente diventa più ricca»."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "習慣に表示される励ましの一言 — 例：「30分読書すれば心が豊かになる。」"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "습관에 표시될 동기 부여 문구 — 예: 「30분 독서로 더 풍요로운 마음을.」"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Motywujące zdanie wyświetlane przy nawyku — np. „Czytaj 30 minut, a twój umısł będzie bogatszy“."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma frase motivadora que você verá no hábito — p. ex. «Leia 30 minutos e sua mente fica mais rica»."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мотивирующая фраза для привычки — напр., «Читайте 30 минут — ваш ум станет богаче»."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alışkanlıkta göreceğiniz motive edici cümle — örn. «30 dakika okumak zihninizi zenginleştirir»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在习惯中显示的激励语 — 例如「坚持阅读30分钟，让思维更丰富。」"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在習慣中顯示的激勵語 — 例如「每天閱讀30分鐘，讓思維更豐富。」"
          }
        }
      }
    },

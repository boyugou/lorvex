          "stringUnit": {
            "state": "translated",
            "value": "Muestra la tarea de enfoque actual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche la tâche de concentration actuelle."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のフォーカスタスクを表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 집중 작업을 표시합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra a tarefa de foco atual."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показывает текущую задачу фокуса."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "顯示目前的專注任務。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra l'attività di focus attuale."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokazuje bieżące zadanie w skupieniu."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Geçerli odak görevini gösterir."
          }
        }
      }

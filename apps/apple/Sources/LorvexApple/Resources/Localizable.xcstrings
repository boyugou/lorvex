    "recurrence.anchor.schedule.hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Repeats on a fixed schedule, regardless of when you finish."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wiederholt sich nach einem festen Zeitplan, unabhängig davon, wann du fertig bist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se repite según un horario fijo, sin importar cuándo termines."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Se répète selon un calendrier fixe, quel que soit le moment où vous terminez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si ripete secondo una pianificazione fissa, indipendentemente da quando finisci."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完了したタイミングに関係なく、固定スケジュールで繰り返します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "완료 시점과 관계없이 고정된 일정에 따라 반복됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Powtarza się według stałego harmonogramu, niezależnie od tego, kiedy skończysz."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Repete-se num horário fixo, independentemente de quando você terminar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повторяется по фиксированному расписанию, независимо от того, когда вы закончите."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne zaman bitirdiğinizden bağımsız olarak sabit bir programa göre yinelenir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按固定计划重复，与你何时完成无关。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按固定計劃重複，與你何時完成無關。"
          }
        }
      }
    },

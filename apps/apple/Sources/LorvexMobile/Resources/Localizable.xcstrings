    "setup.done.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nutze „Erfassen“, um Aufgaben schnell zu sichern, und organisiere sie dann in „Heute“ oder „Listen“."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use Capture to save tasks quickly, then organize them from Today or Lists."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa «Capturar» para guardar tareas rápidamente y luego organízalas desde «Hoy» o «Listas»."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez « Capturer » pour enregistrer rapidement des tâches, puis organisez-les depuis « Aujourd’hui » ou « Listes »."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa «Cattura» per salvare rapidamente le attività, poi organizzale da «Oggi» o «Elenchi»."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「キャプチャ」を使ってタスクをすばやく保存し、「今日」や「リスト」から整理しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "‘캡처’로 작업을 빠르게 저장한 다음 ‘오늘’이나 ‘목록’에서 정리하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Użyj „Przechwyć”, aby szybko zapisywać zadania, a potem porządkuj je w „Dzisiaj” lub „Listy”."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Use “Capturar” para salvar tarefas rapidamente e depois organize-as em “Hoje” ou “Listas”."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте «Захват», чтобы быстро сохранять задачи, а затем упорядочивайте их в разделах «Сегодня» или «Списки»."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Görevleri hızlıca kaydetmek için Yakala'yı kullanın, ardından bunları Bugün veya Listeler'de düzenleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用“捕捉”快速保存任务，然后在“今天”或“清单”中整理它们。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用「擷取」快速儲存任務，然後在「今天」或「列表」中整理它們。"
          }
        }
      }
    },

        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "취소할 작업 없음"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Brak zadania do anulowania"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma tarefa para cancelar"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет задачи для отмены"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İptal edilecek görev yok"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有可取消的任务"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "沒有可取消的任務"
          }
        }
      }
    },

    "memory.delete.confirm.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Eintrag und sein Verlauf werden entfernt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The memory entry is removed. This can't be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La entrada de memoria y su historial se eliminan. Esta acción no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'entrée de mémoire et son historique sont supprimés. Cette action est irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La voce di memoria e la sua cronologia vengono rimosse. L'azione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メモリーのエントリとその履歴が削除されます。この操作は取り消せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메모리 항목과 기록이 삭제됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wpis pamięci i jego historia zostaną usunięte. Tej operacji nie można cofnąć."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A entrada de memória e seu histórico são removidos. Isso não pode ser desfeito."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запись памяти и её история будут удалены. Это действие нельзя отменить."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bellek girişi ve geçmişi kaldırılır. Bu işlem geri alınamaz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该记忆条目及其历史记录将被删除，此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此記憶項目及其歷史記錄將被刪除，此操作無法復原。"
          }
        }
      }
    },

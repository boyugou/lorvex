          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma conta do iCloud. Inicie sessão em Ajustes do Sistema > Conta Apple."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет учётной записи iCloud. Войдите через «Системные настройки» > «Аккаунт Apple»."
          }
        },
        "tr": {
          "stringUnit": {

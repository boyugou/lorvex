    "watch.error.retry.hint": {
      "comment": "Accessibility hint for the retry button",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lädt Fokusdaten aus dem Snapshot oder dem gekoppelten iPhone neu"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reloads focus data from the snapshot or paired iPhone"
          }
        },
        "es": {
          "stringUnit": {

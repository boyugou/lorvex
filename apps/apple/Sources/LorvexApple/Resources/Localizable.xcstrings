    "recurrence.anchor.completion.hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The next one is scheduled relative to when you complete this, so a late finish pushes it forward."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der nächste Termin richtet sich danach, wann du dies abschließt – ein späterer Abschluss verschiebt ihn nach hinten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La siguiente se programa en función de cuándo completes esta, así que terminar tarde la desplaza hacia adelante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La prochaine est planifiée en fonction du moment où vous terminez celle-ci ; un achèvement tardif la décale d'autant."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La prossima viene pianificata in base a quando completi questa, quindi un completamento in ritardo la sposta in avanti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次回はこのタスクを完了したタイミングを基準に予定されるため、完了が遅れるとその分先に延びます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다음 항목은 이 작업을 완료한 시점을 기준으로 예약되므로, 늦게 완료하면 그만큼 뒤로 밀립니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Następne zadanie jest planowane względem momentu ukończenia tego, więc późniejsze zakończenie przesuwa je do przodu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A próxima é agendada em relação a quando você concluir esta, então terminar tarde a empurra para frente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Следующее планируется относительно момента выполнения этого, поэтому позднее завершение сдвигает его вперёд."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sonraki, bunu tamamladığınız ana göre planlanır; bu nedenle geç bitirmek onu ileri kaydırır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下一个会以你完成这一个的时间为基准来安排，因此完成得越晚，下一个就顺延得越晚。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "下一個會以你完成這一個的時間為基準來安排，因此完成得越晚，下一個就順延得越晚。"
          }
        }
      }
    },

            "state": "translated",
            "value": "Sync Paused"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sincronización en pausa"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchronisation en pause"
          }
        },
        "it": {
          "stringUnit": {

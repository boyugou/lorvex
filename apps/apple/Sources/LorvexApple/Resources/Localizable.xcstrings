    "settings.reset.widget_cache_warning": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokale Daten wurden gelöscht, aber Lorvex konnte den Widget-Cache nicht leeren. Starte Lorvex neu und lösche die lokalen Daten erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local data was erased, but Lorvex couldn’t clear the widget cache. Restart Lorvex and erase local data again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se borraron los datos locales, pero Lorvex no pudo borrar la caché de widgets. Reinicia Lorvex y vuelve a borrar los datos locales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les données locales ont été effacées, mais Lorvex n’a pas pu vider le cache des widgets. Redémarrez Lorvex et effacez à nouveau les données locales."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I dati locali sono stati cancellati, ma Lorvex non ha potuto svuotare la cache dei widget. Riavvia Lorvex e cancella di nuovo i dati locali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルデータは消去されましたが、Lorvex はウィジェットのキャッシュを消去できませんでした。Lorvex を再起動し、ローカルデータをもう一度消去してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬 데이터는 지워졌지만 Lorvex가 위젯 캐시를 지우지 못했습니다. Lorvex를 재시작하고 로컬 데이터를 다시 지우세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dane lokalne zostały wymazane, ale Lorvex nie mógł wyczyścić pamięci podręcznej widżetów. Uruchom Lorvex ponownie i jeszcze raz wymaż dane lokalne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os dados locais foram apagados, mas o Lorvex não conseguiu limpar o cache dos widgets. Reinicie o Lorvex e apague os dados locais novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Локальные данные удалены, но Lorvex не удалось очистить кэш виджетов. Перезапустите Lorvex и снова удалите локальные данные."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yerel veriler silindi, ancak Lorvex araç takımı önbelleğini temizleyemedi. Lorvex’i yeniden başlatıp yerel verileri tekrar silin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本地数据已清除，但 Lorvex 无法清除小组件缓存。请重新启动 Lorvex，并再次清除本地数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本機資料已清除，但 Lorvex 無法清除小工具快取。請重新啟動 Lorvex，並再次清除本機資料。"
          }
        }
      }
    },

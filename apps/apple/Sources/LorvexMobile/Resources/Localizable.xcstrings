    "settings.calendar.access.busy_only_detail": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur belegte Zeit spiegeln – Ereignistitel, Orte und Notizen werden ausgeblendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mirror occupied time only — event titles, locations, and notes are hidden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reflejar solo el tiempo ocupado: los títulos, ubicaciones y notas del evento se ocultan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchroniser uniquement le temps occupé — les titres, lieux et notes des événements sont masqués."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rispecchia solo il tempo occupato — titoli, luoghi e note degli eventi sono nascosti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "占有時間のみをミラーリングします。イベントのタイトル、場所、メモは非表示になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용 중인 시간만 미러링합니다. 이벤트 제목, 위치, 메모는 숨겨집니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odzwierciedlaj tylko zajęty czas — tytuły, lokalizacje i notatki wydarzeń są ukryte."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Espelhar apenas o tempo ocupado — os títulos, locais e notas dos eventos ficam ocultos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Зеркалировать только занятое время — названия событий, места и заметки скрыты."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca dolu zamanı yansıt — etkinlik başlıkları, konumlar ve notlar gizlenir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只同步占用时间，隐藏事件标题、地点和备注。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "只同步佔用時間，隱藏事件標題、地點和備註。"
          }
        }
      }
    },

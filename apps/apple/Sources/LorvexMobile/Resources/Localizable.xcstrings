          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokazuj notatki zadania w powiadomieniach"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostrar notas de tarefa nas notificações"
          }
        },
        "ru": {

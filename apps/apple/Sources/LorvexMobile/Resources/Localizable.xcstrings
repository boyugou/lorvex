    "tasks.detail.empty.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle eine Aufgabe aus der Arbeitsbereichsliste, um Details und Aktionen zu prüfen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose a task from the workspace list to inspect details and actions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige una tarea de la lista del espacio de trabajo para inspeccionar sus detalles y acciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une tâche dans la liste de l'espace de travail pour en examiner les détails et les actions."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli un'attività dall'elenco dell'area di lavoro per esaminarne i dettagli e le azioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ワークスペースのリストからタスクを選んで、詳細と操作を確認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작업 공간 목록에서 작업을 선택해 세부 정보와 동작을 확인하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz zadanie z listy obszaru roboczego, aby przejrzeć szczegóły i działania."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha uma tarefa na lista do espaço de trabalho para inspecionar os detalhes e as ações."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите задачу из списка рабочей области, чтобы просмотреть подробности и действия."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ayrıntıları ve eylemleri incelemek için çalışma alanı listesinden bir görev seçin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从工作区列表中选择一个任务，以查看详情和操作。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從工作區清單中選擇一個任務，以檢視詳細資料與操作。"
          }
        }
      }
    },

    "system.task.reminders.upcoming.read.description": {
      "comment": "Description for the Read Lorvex Upcoming Task Reminders App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausstehende Lorvex-Aufgabenerinnerungen lesen, die bald anstehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read pending Lorvex task reminders coming up soon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee los recordatorios de tareas pendientes de Lorvex que vencerán pronto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lire les rappels de tâches Lorvex en attente arrivant bientôt."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Leggi i promemoria delle attività Lorvex in sospeso in arrivo a breve."

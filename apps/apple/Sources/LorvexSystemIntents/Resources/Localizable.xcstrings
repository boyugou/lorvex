    "system.calendar.create.description": {
      "comment": "Description for the Create Lorvex Calendar Event App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle einen Lorvex-Kalendertermin über Kurzbefehle oder Siri."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a Lorvex calendar event from Shortcuts or Siri."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea un evento de calendario de Lorvex desde Atajos o Siri."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez un événement de calendrier Lorvex depuis Raccourcis ou Siri."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea un evento di calendario Lorvex da Comandi rapidi o Siri."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットや Siri から Lorvex カレンダーイベントを作成します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축어나 Siri에서 Lorvex 캘린더 이벤트를 생성합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Utwórz wydarzenie w kalendarzu Lorvex ze Skrótów lub Siri."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie um evento de calendário do Lorvex a partir dos Atalhos ou da Siri."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создайте событие календаря Lorvex через «Быстрые команды» или Siri."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısayollar veya Siri ile bir Lorvex takvim etkinliği oluştur."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从“快捷指令”或 Siri 创建一个 Lorvex 日历事件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從「捷徑」或 Siri 建立一個 Lorvex 行事曆事件。"
          }
        }
      }
    },
    "system.calendar.create.dialog": {
      "comment": "Dialog after creating a calendar event; first %@ is event title and second %@ is start date",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalendertermin %@ für %@ erstellt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Created calendar event %@ for %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se creó el evento de calendario %@ para %@."
          }
        },
        "fr": {

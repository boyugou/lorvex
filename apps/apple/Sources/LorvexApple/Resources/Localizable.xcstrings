    "setup.permissions.calendar.description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Titel, Zeiten, Orte, Notizen und Wiederholungsdetails von Terminen für die Planung importieren. Kalenderdaten können verbundenen Assistenten zur Verfügung stehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Import event titles, times, locations, notes, and recurrence details for planning. Calendar data may be available to connected assistants."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa títulos, horarios, ubicaciones, notas y detalles de recurrencia de los eventos para planificar. Los datos del calendario pueden estar disponibles para los asistentes conectados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Importer les titres, horaires, lieux, notes et détails de récurrence des événements à des fins de planification. Les données du calendrier peuvent être accessibles aux assistants connectés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa titoli, orari, luoghi, note e dettagli di ricorrenza degli eventi per la pianificazione. I dati del calendario potrebbero essere accessibili agli assistenti connessi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "予定の作成に役立てるため、イベントのタイトル、時刻、場所、メモ、繰り返しの詳細を取り込みます。接続されたアシスタントがカレンダーデータを利用できる場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계획을 위해 이벤트 제목, 시간, 위치, 메모 및 반복 세부사항을 가져옵니다. 연결된 어시스턴트가 캘린더 데이터에 접근할 수도 있습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Importuje tytuły, godziny, lokalizacje, notatki i szczegóły cykliczności wydarzeń na potrzeby planowania. Dane kalendarza mogą być dostępne dla połączonych asystentów."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa títulos, horários, locais, notas e detalhes de recorrência dos eventos para o planejamento. Os dados do calendário podem ficar disponíveis para assistentes conectados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Импортирует названия, время, места, заметки и сведения о повторении событий для планирования. Данные календаря могут быть доступны подключённым ассистентам."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Planlama için etkinlik başlıklarını, saatlerini, konumlarını, notlarını ve yineleme ayrıntılarını içe aktarır. Takvim verileri bağlı asistanların kullanımına sunulabilir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导入事件的标题、时间、地点、备注和重复详情，用于规划。已连接的助手可能能够访问日历数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "匯入事件的標題、時間、地點、備註和重複詳細資訊，用於規劃。已連接的助理可能可以存取行事曆資料。"
          }
        }
      }
    },

    "settings.activity.retention.footer.off": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Aus“ beendet die Aufzeichnung und löscht vorhandene Einträge auf all deinen Geräten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Off stops recording and clears existing entries on all your devices."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La opción «Desactivado» detiene el registro y borra las entradas existentes en todos tus dispositivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’option « Désactivé » arrête l’enregistrement et efface les entrées existantes sur tous vos appareils."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L’opzione “Disattivato” interrompe la registrazione e cancella le voci esistenti su tutti i tuoi dispositivi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフにすると記録を停止し、すべてのデバイス上の既存の項目を消去します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "끔으로 설정하면 기록을 중지하고 모든 기기의 기존 항목을 삭제합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyłączenie zatrzymuje rejestrowanie i usuwa istniejące wpisy na wszystkich Twoich urządzeniach."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A opção Desativado interrompe o registro e apaga as entradas existentes em todos os seus dispositivos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Режим «Выкл.» прекращает запись и удаляет существующие записи на всех ваших устройствах."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kapalı seçeneği günlüğe kaydı durdurur ve tüm aygıtlarınızdaki mevcut girdileri temizler."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭后将停止记录，并清除你所有设备上的现有条目。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關閉後將停止記錄，並清除你所有裝置上的現有項目。"
          }
        }
      }
    },
    "settings.activity.retention.footer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ältere Einträge werden bei der Synchronisierung entfernt. „Aus“ beendet die Aufzeichnung und löscht vorhandene Einträge auf all deinen Geräten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Older entries are trimmed on sync. Off stops recording and clears existing entries on all your devices."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las entradas antiguas se eliminan durante la sincronización. La opción «Desactivado» detiene el registro y borra las entradas existentes en todos tus dispositivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les entrées les plus anciennes sont supprimées lors de la synchronisation. L’option « Désactivé » arrête l’enregistrement et efface les entrées existantes sur tous vos appareils."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le voci meno recenti vengono eliminate durante la sincronizzazione. L’opzione “Disattivato” interrompe la registrazione e cancella le voci esistenti su tutti i tuoi dispositivi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "古い項目は同期時に削除されます。オフにすると記録を停止し、すべてのデバイス上の既存の項目を消去します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오래된 항목은 동기화할 때 삭제됩니다. 끔으로 설정하면 기록을 중지하고 모든 기기의 기존 항목을 삭제합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Starsze wpisy są usuwane podczas synchronizacji. Wyłączenie zatrzymuje rejestrowanie i usuwa istniejące wpisy na wszystkich Twoich urządzeniach."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As entradas mais antigas são removidas durante a sincronização. A opção Desativado interrompe o registro e apaga as entradas existentes em todos os seus dispositivos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Старые записи удаляются при синхронизации. Режим «Выкл.» прекращает запись и удаляет существующие записи на всех ваших устройствах."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Eski girdiler eşitleme sırasında silinir. Kapalı seçeneği günlüğe kaydı durdurur ve tüm aygıtlarınızdaki mevcut girdileri temizler."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "较早的条目会在同步时清理。关闭后将停止记录，并清除你所有设备上的现有条目。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",

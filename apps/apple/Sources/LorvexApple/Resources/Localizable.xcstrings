          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum evento do calendário é lido no Lorvex."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "События календаря не считываются в Lorvex."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex'e hiç takvim etkinliği okunmuyor."
          }
        },
        "zh-Hans": {
          "stringUnit": {

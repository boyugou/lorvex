      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwandte Aufgaben in einer Liste gruppieren — oder deinen KI-Assistenten fragen."
          }
        },
        "en": {
          "stringUnit": {

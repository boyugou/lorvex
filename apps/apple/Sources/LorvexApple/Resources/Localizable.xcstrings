            "value": "カレンダーのイベントは Lorvex に読み込まれません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캘린더 이벤트가 Lorvex로 읽어들여지지 않습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",

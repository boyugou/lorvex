        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Redefinir este hábito? As conclusões registradas serão apagadas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сбросить эту привычку? Записанные выполнения будут удалены."

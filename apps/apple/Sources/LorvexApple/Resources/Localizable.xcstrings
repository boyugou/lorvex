    "list_row.archive.nonempty_count_message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "„%2$@“ kann nicht gelöscht werden, solange sie noch %1$lld Aufgabe enthält. Archiviere sie stattdessen, um sie stillzulegen und dabei Aufgaben und Verlauf zu behalten. Du kannst sie später wiederherstellen."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "„%2$@“ kann nicht gelöscht werden, solange sie noch %1$lld Aufgaben enthält. Archiviere sie stattdessen, um sie stillzulegen und dabei Aufgaben und Verlauf zu behalten. Du kannst sie später wiederherstellen."
                }
              }
            }
          }
        },
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "\"%2$@\" can't be deleted while it still holds %1$lld task. Archive it instead to retire it while keeping its tasks and history. You can unarchive it later."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "\"%2$@\" can't be deleted while it still holds %1$lld tasks. Archive it instead to retire it while keeping its tasks and history. You can unarchive it later."
                }
              }
            }
          }
        },
        "es": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "«%2$@» no se puede eliminar mientras contenga %1$lld tarea. Archívala en su lugar para retirarla conservando sus tareas y su historial. Puedes desarchivarla más tarde."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "«%2$@» no se puede eliminar mientras contenga %1$lld tareas. Archívala en su lugar para retirarla conservando sus tareas y su historial. Puedes desarchivarla más tarde."
                }
              }
            }
          }
        },
        "fr": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "« %2$@ » ne peut pas être supprimée tant qu'elle contient %1$lld tâche. Archivez-la plutôt pour la retirer tout en conservant ses tâches et son historique. Vous pourrez la désarchiver plus tard."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "« %2$@ » ne peut pas être supprimée tant qu'elle contient %1$lld tâches. Archivez-la plutôt pour la retirer tout en conservant ses tâches et son historique. Vous pourrez la désarchiver plus tard."
                }
              }
            }
          }
        },
        "it": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "«%2$@» non può essere eliminato finché contiene %1$lld attività. Archivialo invece per metterlo da parte mantenendone attività e cronologia. Potrai ripristinarlo in seguito."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "«%2$@» non può essere eliminato finché contiene %1$lld attività. Archivialo invece per metterlo da parte mantenendone attività e cronologia. Potrai ripristinarlo in seguito."
                }
              }
            }
          }
        },
        "ja": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld 件のタスクが残っているため、「%2$@」は削除できません。代わりにアーカイブすると、タスクと履歴を保持したまま整理できます。後でアーカイブを解除できます。"
                }
              }
            }
          }
        },
        "ko": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld개의 작업이 남아 있어 \"%2$@\"을(를) 삭제할 수 없습니다. 대신 보관하면 작업과 기록을 유지한 채 정리할 수 있습니다. 나중에 보관을 해제할 수 있습니다."
                }
              }
            }
          }
        },
        "pl": {
          "variations": {
            "plural": {
              "few": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Nie można usunąć listy „%2$@”, dopóki zawiera %1$lld zadania. Zamiast tego zarchiwizuj ją, aby ją wycofać, zachowując zadania i historię. Możesz ją później przywrócić."
                }
              },
              "many": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Nie można usunąć listy „%2$@”, dopóki zawiera %1$lld zadań. Zamiast tego zarchiwizuj ją, aby ją wycofać, zachowując zadania i historię. Możesz ją później przywrócić."
                }
              },
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Nie można usunąć listy „%2$@”, dopóki zawiera %1$lld zadanie. Zamiast tego zarchiwizuj ją, aby ją wycofać, zachowując zadania i historię. Możesz ją później przywrócić."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Nie można usunąć listy „%2$@”, dopóki zawiera %1$lld zadania. Zamiast tego zarchiwizuj ją, aby ją wycofać, zachowując zadania i historię. Możesz ją później przywrócić."
                }
              }
            }
          }
        },
        "pt": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "\"%2$@\" não pode ser excluída enquanto contém %1$lld tarefa. Em vez disso, arquive-a para retirá-la mantendo suas tarefas e seu histórico. Você pode desarquivá-la depois."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "\"%2$@\" não pode ser excluída enquanto contém %1$lld tarefas. Em vez disso, arquive-a para retirá-la mantendo suas tarefas e seu histórico. Você pode desarquivá-la depois."
                }
              }
            }
          }
        },
        "ru": {
          "variations": {
            "plural": {
              "few": {
                "stringUnit": {
                  "state": "translated",
                  "value": "«%2$@» нельзя удалить, пока в нём остаётся %1$lld задачи. Вместо этого архивируйте его, сохранив задачи и историю. Позже его можно вернуть из архива."
                }
              },
              "many": {
                "stringUnit": {
                  "state": "translated",
                  "value": "«%2$@» нельзя удалить, пока в нём остаётся %1$lld задач. Вместо этого архивируйте его, сохранив задачи и историю. Позже его можно вернуть из архива."
                }
              },
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "«%2$@» нельзя удалить, пока в нём остаётся %1$lld задача. Вместо этого архивируйте его, сохранив задачи и историю. Позже его можно вернуть из архива."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "«%2$@» нельзя удалить, пока в нём остаётся %1$lld задачи. Вместо этого архивируйте его, сохранив задачи и историю. Позже его можно вернуть из архива."
                }
              }
            }
          }
        },
        "tr": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "\"%2$@\" hâlâ %1$lld görev içerdiği için silinemez. Bunun yerine görevlerini ve geçmişini koruyarak kaldırmak için arşivleyin. Daha sonra arşivden çıkarabilirsiniz."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "\"%2$@\" hâlâ %1$lld görev içerdiği için silinemez. Bunun yerine görevlerini ve geçmişini koruyarak kaldırmak için arşivleyin. Daha sonra arşivden çıkarabilirsiniz."
                }
              }
            }
          }
        },
        "zh-Hans": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "“%2$@”仍有 %1$lld 个任务，无法删除。可改为归档，保留任务和历史记录的同时将其收起。你之后可以取消归档。"
                }
              }
            }
          }
        },
        "zh-Hant": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "「%2$@」仍有 %1$lld 個任務，無法刪除。可改為封存，保留任務和歷史記錄的同時將其收起。你之後可以取消封存。"
                }
              }
            }
          }
        }
      }
    },

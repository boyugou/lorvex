    "task_detail.empty.no_selection_description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle eine Aufgabe aus „Heute“, „Aufgaben“, „Listen“ oder „Kalender“, um ihre Details hier anzusehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select a task from Today, Tasks, Lists, or Calendar to review its details here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona una tarea de Hoy, Tareas, Listas o Calendario para revisar sus detalles aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez une tâche dans Aujourd’hui, Tâches, Listes ou Calendrier pour en consulter les détails ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleziona un’attività da Oggi, Attività, Elenchi o Calendario per esaminarne i dettagli qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「今日」「タスク」「リスト」「カレンダー」からタスクを選択すると、ここで詳細を確認できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘, 작업, 목록 또는 캘린더에서 작업을 선택하면 여기에서 세부 정보를 볼 수 있습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz zadanie z Dziś, Zadań, List lub Kalendarza, aby przejrzeć jego szczegóły tutaj."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleciona uma tarefa de Hoje, Tarefas, Listas ou Calendário para rever os detalhes aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите задачу из «Сегодня», «Задачи», «Списки» или «Календарь», чтобы просмотреть её детали здесь."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ayrıntılarını burada görmek için Bugün, Görevler, Listeler veya Takvim’den bir görev seç."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从“今天”、“任务”、“列表”或“日历”中选择一个任务，即可在此查看其详情。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從「今天」、「任務」、「列表」或「日曆」中選擇一個任務，即可在此查看其詳情。"
          }
        }
      }
    },

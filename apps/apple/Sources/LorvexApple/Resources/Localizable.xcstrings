    "tips.daily_review.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schließe deinen Tag mit einer kurzen Reflexion ab. Lorvex kann sie geräteübergreifend synchronisieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wrap up your day with a quick reflection. Lorvex can sync it across devices."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cierra tu día con una breve reflexión. Lorvex puede sincronizarla entre dispositivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminez votre journée par une brève réflexion. Lorvex peut la synchroniser sur tous vos appareils."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Concludi la tua giornata con una breve riflessione. Lorvex può sincronizzarla tra i dispositivi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "短い振り返りで一日を締めくくりましょう。Lorvex がデバイス間で同期できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "짧은 회고로 하루를 마무리하세요. Lorvex가 기기 간에 동기화할 수 있습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zakończ dzień krótką refleksją. Lorvex może ją zsynchronizować między urządzeniami."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Encerre o seu dia com uma breve reflexão. O Lorvex pode sincronizá-la entre dispositivos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Завершите свой день короткой рефлексией. Lorvex может синхронизировать её между устройствами."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gününüzü hızlı bir değerlendirmeyle tamamlayın. Lorvex bunu cihazlar arasında eşitleyebilir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用简短反思结束一天，Lorvex 可以在设备间同步。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用簡短反思結束一天，Lorvex 可以在裝置間同步。"
          }
        }
      }
    },

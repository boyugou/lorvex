    "permissions.footer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex fragt nur in sinnvollen Momenten nach Berechtigungen. Tippe auf „Einstellungen öffnen“, um den Zugriff in den Systemeinstellungen anzupassen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex requests permissions only at meaningful moments. Tap \"Open Settings\" to adjust access in System Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex solicita permisos solo en momentos significativos. Toca «Abrir Ajustes» para ajustar el acceso en Ajustes del Sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex demande des autorisations uniquement à des moments pertinents. Touchez « Ouvrir Réglages » pour ajuster l'accès dans Réglages Système."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex richiede le autorizzazioni solo nei momenti significativi. Tocca \"Apri Impostazioni\" per regolare l'accesso in Impostazioni di Sistema."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvexは意味のあるタイミングでのみ権限を要求します。「設定を開く」をタップしてシステム設定でアクセスを調整できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex는 의미 있는 순간에만 권한을 요청합니다. '설정 열기'를 탭하여 시스템 설정에서 접근 권한을 조정하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex prosi o uprawnienia tylko w istotnych momentach. Dotknij „Otwórz Ustawienia”, aby dostosować dostęp w Ustawieniach systemowych."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lorvex solicita permissões apenas em momentos relevantes. Toque em «Abrir Ajustes» para ajustar o acesso nos Ajustes do Sistema."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex запрашивает разрешения только в значимые моменты. Нажмите «Открыть настройки», чтобы изменить доступ в Системных настройках."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex izinleri yalnızca anlamlı anlarda ister. Sistem Ayarları'nda erişimi düzenlemek için \"Ayarları Aç\"a dokunun."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 仅在必要时请求权限。点按“打开设置”可在系统设置中调整访问权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 僅在必要時請求權限。點按「打開設定」可在系統設定中調整存取權限。"
          }
        }
      }
    },

          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повторно открывает завершённую, отменённую или отложенную задачу Lorvex."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",

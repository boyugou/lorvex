          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Lê os lembretes de tarefas pendentes do Lorvex que vencem em breve."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чтение ожидающих напоминаний о задачах Lorvex, которые скоро наступят."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yakında gelecek bekleyen Lorvex görev hatırlatıcılarını oku."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "读取即将到来的待处理 Lorvex 任务提醒。"
          }

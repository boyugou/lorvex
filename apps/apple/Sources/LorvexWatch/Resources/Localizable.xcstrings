          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricarica i dati di focus dallo snapshot o dall'iPhone abbinato"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スナップショットまたはペアリングしたiPhoneからフォーカスデータを再読み込みします"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스냅샷 또는 페어링된 iPhone에서 집중 데이터를 다시 불러옵니다"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ponownie wczytuje dane skupienia z migawki lub sparowanego iPhone'a"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Recarrega os dados de foco a partir do instantâneo ou do iPhone emparelhado"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перезагружает данные фокуса из снимка или сопряжённого iPhone"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Odak verilerini anlık görüntüden veya eşleştirilmiş iPhone'dan yeniden yükler"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从快照或已配对的 iPhone 重新加载专注数据"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從快照或已配對的 iPhone 重新載入專注資料"
          }
        }
      }
    },

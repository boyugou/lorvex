          "stringUnit": {
            "state": "translated",
            "value": "この習慣の今日のチェックインを消去します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 습관의 오늘 체크인을 모두 지웁니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to usunięcie dzisiejszych odhaczeń tego nawyku."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto apaga os registos de hoje deste hábito."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это удалит сегодняшние отметки по этой привычке."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, bu alışkanlığın bugünkü girişlerini siler."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将清除该习惯今天的打卡记录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將清除此習慣今天的打卡記錄。"
          }
        }
      }
    },

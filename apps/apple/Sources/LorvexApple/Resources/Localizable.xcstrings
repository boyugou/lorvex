    "settings.mcp.connect_blurb": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein KI-Client startet Lorvex' integrierten Helfer, um Lorvex-Daten zu lesen und zu aktualisieren – darunter Aufgaben, Listen, Gewohnheiten, Erinnerung, Rückblicke und Kalendereinträge. Kopiere den Einrichtungs-Prompt unten nur in Assistenten, denen du vertraust."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your AI client launches Lorvex's built-in helper to read and update Lorvex data, including tasks, lists, habits, memory, reviews, and calendar entries. Copy the setup prompt below only into assistants you trust."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu cliente de IA inicia el asistente integrado de Lorvex para leer y actualizar los datos de Lorvex, incluidas tareas, listas, hábitos, memoria, revisiones y eventos de calendario. Copia el mensaje de configuración de abajo solo en asistentes de confianza."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre client IA lance l’assistant intégré de Lorvex pour lire et mettre à jour les données de Lorvex, dont les tâches, listes, habitudes, mémoire, bilans et entrées de calendrier. Ne copiez l’invite de configuration ci-dessous que dans des assistants de confiance."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo client IA avvia l’helper integrato di Lorvex per leggere e aggiornare i dati di Lorvex, tra cui attività, elenchi, abitudini, memoria, revisioni e voci di calendario. Copia il prompt di configurazione qui sotto solo in assistenti di cui ti fidi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AI クライアントは Lorvex の内蔵ヘルパーを起動し、タスク、リスト、習慣、メモリー、レビュー、カレンダーの項目など Lorvex のデータを読み書きします。下のセットアッププロンプトは、信頼できるアシスタントにのみ貼り付けてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 클라이언트가 Lorvex의 내장 도우미를 실행하여 작업, 목록, 습관, 메모리, 회고, 캘린더 항목 등 Lorvex 데이터를 읽고 업데이트합니다. 아래 설정 프롬프트는 신뢰하는 어시스턴트에만 붙여넣으세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twój klient AI uruchamia wbudowanego pomocnika Lorvex, aby odczytywać i aktualizować dane Lorvex, w tym zadania, listy, nawyki, pamięć, przeglądy i wpisy kalendarza. Skopiuj poniższy monit konfiguracyjny tylko do zaufanych asystentów."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu cliente de IA inicia o auxiliar integrado do Lorvex para ler e atualizar os dados do Lorvex, incluindo tarefas, listas, hábitos, memória, revisões e itens de calendário. Copie o prompt de configuração abaixo apenas em assistentes confiáveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваш ИИ-клиент запускает встроенный помощник Lorvex для чтения и обновления данных Lorvex, включая задачи, списки, привычки, память, обзоры и записи календаря. Вставляйте приведённый ниже установочный запрос только в помощники, которым доверяете."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yapay zekâ istemciniz, görevler, listeler, alışkanlıklar, hafıza, değerlendirmeler ve takvim öğeleri dahil Lorvex verilerini okuyup güncellemek için Lorvex'in yerleşik yardımcısını başlatır. Aşağıdaki kurulum istemini yalnızca güvendiğiniz asistanlara kopyalayın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 AI 客户端会启动 Lorvex 内置助手，以读取和更新 Lorvex 数据，包括任务、清单、习惯、记忆、回顾和日历条目。请仅将下方的设置提示词复制到你信任的助手中。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 AI 用戶端會啟動 Lorvex 內建輔助程式，以讀取及更新 Lorvex 資料，包括任務、列表、習慣、記憶、回顧和行事曆項目。請僅將下方的設定提示複製到你信任的助理中。"
          }
        }
      }
    },

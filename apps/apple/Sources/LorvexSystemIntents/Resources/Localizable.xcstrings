    "system.tag.find_tasks.description": {
      "comment": "Description for the Find Lorvex Tasks by Tag App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex-Aufgaben mit einem Tag über Kurzbefehle oder Siri finden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find Lorvex tasks carrying a tag from Shortcuts or Siri."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Busca tareas de Lorvex que tengan una etiqueta desde Atajos o Siri."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rechercher des tâches Lorvex portant un tag depuis Raccourcis ou Siri."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trova attività Lorvex con un tag da Comandi rapidi o Siri."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットまたは Siri から、タグの付いた Lorvex タスクを検索します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축어 또는 Siri에서 태그가 지정된 Lorvex 작업을 찾습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Znajdź zadania Lorvex z danym tagiem ze Skrótów lub Siri."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Encontre tarefas do Lorvex que tenham uma tag pelo Atalhos ou pela Siri."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Найти задачи Lorvex с тегом через «Команды» или Siri."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısayollar veya Siri ile etiket taşıyan Lorvex görevlerini bul."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从“快捷指令”或 Siri 查找带有某个标签的 Lorvex 任务。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從「捷徑」或 Siri 尋找帶有某個標籤的 Lorvex 任務。"
          }
        }
      }
    },

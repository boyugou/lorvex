    "habits.sheet.field.milestone_goal_hint_count": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Feiere bei so vielen Abschlüssen. Die Gewohnheit läuft danach weiter."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Celebrate at this many completions. The habit keeps going after."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Celebra al alcanzar esta cantidad de finalizaciones. El hábito continúa después."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Célébrez une fois ce nombre de réalisations atteint. L’habitude continue ensuite."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Festeggia a questo numero di completamenti. L’abitudine prosegue comunque."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この回数の達成でお祝いします。習慣はその後も続きます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 완료 횟수에 도달하면 축하합니다. 습관은 이후에도 계속됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Świętuj po osiągnięciu tylu ukończeń. Nawyk trwa dalej."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Comemore ao atingir esta quantidade de conclusões. O hábito continua depois."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отпразднуйте при таком количестве выполнений. Привычка продолжается и дальше."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu kadar tamamlamada kutlayın. Alışkanlık sonrasında da devam eder."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "达到这么多次完成时庆祝。习惯之后仍会继续。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "達到這麼多次完成時慶祝。習慣之後仍會繼續。"
          }
        }
      }
    },

    "settings.appearance.footer": {
      "comment": "Footer explaining the macOS appearance picker",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„System“ übernimmt die Hell-/Dunkel-Einstellung von macOS; „Hell“ und „Dunkel“ erzwingen dieses Erscheinungsbild überall in Lorvex."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "System follows your macOS Light/Dark setting; Light and Dark force that appearance everywhere in Lorvex."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«Sistema» sigue el ajuste claro/oscuro de macOS; «Claro» y «Oscuro» fuerzan esa apariencia en todo Lorvex."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Système » suit le réglage clair/sombre de macOS ; « Clair » et « Sombre » imposent cette apparence partout dans Lorvex."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistema segue l'impostazione Chiaro/Scuro di macOS; Chiaro e Scuro forzano quell'aspetto ovunque in Lorvex."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「システム」は macOS のライト/ダーク設定に従います。「ライト」と「ダーク」は Lorvex 全体でその外観を強制します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "‘시스템’은 macOS의 라이트/다크 설정을 따릅니다. ‘라이트’와 ‘다크’는 Lorvex 전체에서 해당 외관을 강제로 적용합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "System podąża za ustawieniem Jasny/Ciemny macOS; Jasny i Ciemny wymuszają ten wygląd wszędzie w Lorvex."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "“Sistema” segue a configuração Claro/Escuro do macOS; “Claro” e “Escuro” forçam essa aparência em todo o Lorvex."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "«Системная» использует настройку светлой/тёмной темы macOS; «Светлая» и «Тёмная» принудительно применяют это оформление везде в Lorvex."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem, macOS Açık/Koyu ayarınızı izler; Açık ve Koyu, Lorvex'in her yerinde o görünümü zorunlu kılar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“跟随系统”会采用 macOS 的浅色/深色设置；“浅色”和“深色”则会在 Lorvex 中始终强制使用该外观。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「跟隨系統」會採用 macOS 的淺色/深色設定；「淺色」和「深色」則會在 Lorvex 中一律強制使用該外觀。"
          }
        }
      }
    },

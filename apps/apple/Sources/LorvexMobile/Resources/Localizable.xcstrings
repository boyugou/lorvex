    "list_detail.delete_confirm.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur leere Listen können gelöscht werden. Listen mit zugewiesenen Aufgaben müssen zuerst geleert werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only empty lists can be deleted. Lists with assigned tasks must be cleared first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo se pueden eliminar las listas vacías. Las listas con tareas asignadas deben vaciarse primero."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seules les listes vides peuvent être supprimées. Les listes avec des tâches assignées doivent d'abord être vidées."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si possono eliminare solo gli elenchi vuoti. Gli elenchi con attività assegnate devono prima essere svuotati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "空のリストのみ削除できます。タスクが割り当てられたリストは先に空にする必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "비어 있는 목록만 삭제할 수 있습니다. 작업이 할당된 목록은 먼저 비워야 합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Można usuwać tylko puste listy. Listy z przypisanymi zadaniami trzeba najpierw wyczyścić."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas listas vazias podem ser excluídas. Listas com tarefas atribuídas devem ser esvaziadas primeiro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалять можно только пустые списки. Списки с назначенными задачами нужно сначала очистить."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca boş listeler silinebilir. Atanmış görevleri olan listeler önce temizlenmelidir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只能删除空列表。包含已分配任务的列表必须先清空。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "只能刪除空清單。包含已指派任務的清單必須先清空。"
          }
        }
      }
    },

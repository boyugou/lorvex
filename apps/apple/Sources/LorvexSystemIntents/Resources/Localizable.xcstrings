            "value": "Zaktualizuj szczegóły zadania Lorvex ze Skrótów lub Siri."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Atualize os detalhes de uma tarefa do Lorvex pelos Atalhos ou pela Siri."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обновляйте сведения о задаче Lorvex с помощью «Команд» или Siri."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",

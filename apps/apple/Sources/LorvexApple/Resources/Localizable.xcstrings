    "recurring_cancel.batch_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel only the selected occurrences, or end every selected repeating series?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur die ausgewählten Vorkommen abbrechen oder alle ausgewählten Serien beenden?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cancelar solo las repeticiones seleccionadas o finalizar todas las series recurrentes seleccionadas?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Annuler uniquement les occurrences sélectionnées ou mettre fin à toutes les séries récurrentes sélectionnées ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Annullare solo le occorrenze selezionate o terminare tutte le serie ricorrenti selezionate?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択した回だけをキャンセルしますか、それとも選択したすべての繰り返しタスクを終了しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 항목만 취소하시겠습니까, 아니면 선택한 모든 반복 작업을 종료하시겠습니까?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Anulować tylko wybrane wystąpienia czy zakończyć wszystkie wybrane serie powtarzających się zadań?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancelar apenas as ocorrências selecionadas ou encerrar todas as séries recorrentes selecionadas?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отменить только выбранные повторения или завершить все выбранные серии повторений?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca seçili tekrarlar mı iptal edilsin, yoksa seçili yinelenen serilerin tümü mü sonlandırılsın?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只取消所选的这几次，还是结束所有选中的重复系列？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "只取消所選的這幾次，還是結束所有選取的重複系列？"
          }
        }
      }
    },

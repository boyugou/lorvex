    "watch.error.unavailable.remedy": {
      "comment": "Remedy text when the watch snapshot is unavailable",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffne Lorvex auf deinem iPhone, um zu synchronisieren, und versuche es dann erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Lorvex on your iPhone to sync, then retry."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre Lorvex en tu iPhone para sincronizar y luego vuelve a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez Lorvex sur votre iPhone pour synchroniser, puis réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri Lorvex sul tuo iPhone per sincronizzare, poi riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同期するには iPhone で Lorvex を開き、再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "동기화하려면 iPhone에서 Lorvex를 연 다음 다시 시도하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Otwórz Lorvex na iPhonie, aby zsynchronizować, a następnie ponów."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra o Lorvex no seu iPhone para sincronizar e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте Lorvex на iPhone для синхронизации, затем повторите попытку."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",

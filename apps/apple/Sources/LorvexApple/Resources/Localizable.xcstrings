    "habits.row.reset_confirm.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies löscht die heutigen Eintragungen für diese Gewohnheit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This clears today's check-ins for this habit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto borra los registros de hoy de este hábito."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela efface les validations d’aujourd’hui pour cette habitude."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo cancella le registrazioni di oggi per questa abitudine."
          }

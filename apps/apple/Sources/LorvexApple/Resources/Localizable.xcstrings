    "detached_window.placeholder.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle ein Objekt im Hauptfenster aus – oder es wurde möglicherweise auf einem anderen Gerät gelöscht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select an item from the main window — or it may have been deleted on another device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona un elemento en la ventana principal, o puede que se haya eliminado en otro dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez un élément dans la fenêtre principale — ou il a peut-être été supprimé sur un autre appareil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleziona un elemento dalla finestra principale — oppure potrebbe essere stato eliminato su un altro dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メインウインドウから項目を選択してください。または別のデバイスで削除された可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본 윈도우에서 항목을 선택하거나, 다른 기기에서 삭제되었을 수 있습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz element z okna głównego — albo mógł zostać usunięty na innym urządzeniu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecione um item na janela principal — ou ele pode ter sido excluído em outro dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите объект в главном окне — или он мог быть удалён на другом устройстве."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ana pencereden bir öğe seçin — ya da başka bir cihazda silinmiş olabilir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在主窗口选择一个项目，或该项目可能已在另一台设备上删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請在主視窗選擇一個項目，或該項目可能已在另一台裝置上刪除。"
          }
        }
      }
    },

    "system.task.cancel.description": {
      "comment": "Description for cancelling only one Lorvex task occurrence while preserving future occurrences",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Brich diese Wiederholung einer Lorvex-Aufgabe über Kurzbefehle oder Siri ab. Zukünftige Wiederholungen bleiben bestehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel this Lorvex task occurrence from Shortcuts or Siri. Repeating tasks continue."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancela esta repetición de una tarea de Lorvex desde Atajos o Siri. Las repeticiones futuras continúan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Annulez cette occurrence d’une tâche Lorvex depuis Raccourcis ou Siri. Les occurrences suivantes restent actives."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Annulla questa occorrenza di un’attività Lorvex da Comandi rapidi o Siri. Le occorrenze future continuano."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットや Siri から Lorvex タスクの今回分のみをキャンセルします。次回以降は継続されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축어나 Siri에서 Lorvex 작업의 이번 회차만 취소합니다. 이후 회차는 계속됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Anuluj to wystąpienie zadania Lorvex ze Skrótów lub Siri. Kolejne wystąpienia pozostaną aktywne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancele esta ocorrência de uma tarefa do Lorvex pelos Atalhos ou pela Siri. As ocorrências futuras continuam."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отмените это повторение задачи Lorvex через «Быстрые команды» или Siri. Следующие повторения продолжатся."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısayollar veya Siri ile Lorvex görevinin yalnızca bu tekrarını iptal edin. Sonraki tekrarlar devam eder."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过快捷指令或 Siri 仅取消 Lorvex 任务的本次执行。之后的执行仍会继续。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "透過「捷徑」或 Siri 僅取消 Lorvex 任務的本次執行。之後的執行仍會繼續。"
          }
        }
      }
    },

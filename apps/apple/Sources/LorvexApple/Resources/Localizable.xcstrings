          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As alterações entram em vigor após reiniciar o app."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Изменения вступят в силу после перезапуска приложения."

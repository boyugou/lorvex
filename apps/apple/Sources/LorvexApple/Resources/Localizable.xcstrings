    "reviews.weekly.empty.description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wöchentliche Muster erscheinen, sobald Lorvex genügend aktuelle Aufgabenaktivität zum Zusammenfassen hat."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Weekly patterns appear after Lorvex has enough recent task activity to summarize."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los patrones semanales aparecen cuando Lorvex tiene suficiente actividad reciente de tareas para resumir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les tendances hebdomadaires apparaissent une fois que Lorvex dispose de suffisamment d’activité récente à résumer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli andamenti settimanali compaiono quando Lorvex ha abbastanza attività recenti da riassumere."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex が要約できるだけの最近のタスク活動を蓄積すると、毎週の傾向が表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex가 요약할 만큼 최근 작업 활동이 쌓이면 주간 패턴이 표시됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Cotygodniowe wzorce pojawią się, gdy Lorvex zgromadzi wystarczająco dużo bieżącej aktywności do podsumowania."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os padrões semanais aparecem quando o Lorvex tem atividade recente suficiente para resumir."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Еженедельные закономерности появятся, когда у Lorvex накопится достаточно недавней активности для сводки."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex özetleyecek kadar son görev etkinliği biriktirdiğinde haftalık örüntüler görünür."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当 Lorvex 积累了足够的近期任务活动可供总结后，每周的规律就会显示在这里。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",

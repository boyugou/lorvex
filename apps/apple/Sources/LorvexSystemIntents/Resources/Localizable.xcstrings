    "system.memory.read.description": {
      "comment": "Description for the Read Lorvex Memory App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einen Lorvex-Speichereintrag anhand des Schlüssels über Kurzbefehle oder Siri lesen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read a Lorvex memory entry by key from Shortcuts or Siri."
          }

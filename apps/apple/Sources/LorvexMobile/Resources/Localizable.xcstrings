    "review.evidence.empty.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für diesen Tag sind keine erledigten Aufgaben, offenen fälligen Einträge, Gewohnheiten, Ereignisse oder erstellten Aufgaben erfasst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No completed tasks, open due items, habits, events, or created tasks are recorded for this day."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay tareas completadas, pendientes vencidas, hábitos, eventos ni tareas creadas registradas para este día."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune tâche terminée, échéance ouverte, habitude, événement ou tâche créée n’est enregistré pour ce jour."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per questo giorno non risultano attività completate, elementi aperti in scadenza, abitudini, eventi o attività create."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この日に記録された完了タスク、未完了の期限項目、習慣、イベント、作成タスクはありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 날에 기록된 완료 작업, 미완료 기한 항목, 습관, 이벤트 또는 생성된 작업이 없습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dla tego dnia nie zapisano ukończonych zadań, otwartych terminów, nawyków, wydarzeń ani utworzonych zadań."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma tarefa concluída, item pendente, hábito, evento ou tarefa criada foi registrado para este dia."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "За этот день нет завершенных задач, открытых сроков, привычек, событий или созданных задач."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu gün için tamamlanan görev, açık son tarih, alışkanlık, etkinlik veya oluşturulan görev kaydı yok."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这一天没有记录已完成任务、未完成到期项、习惯、事件或创建的任务。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這一天沒有記錄已完成任務、未完成到期項目、習慣、事件或建立的任務。"
          }
        }
      }

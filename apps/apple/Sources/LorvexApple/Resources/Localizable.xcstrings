    "tasks.loading.description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Prüfliste wird bereitgehalten, während Lorvex die Aufgabendaten aktualisiert."
          }

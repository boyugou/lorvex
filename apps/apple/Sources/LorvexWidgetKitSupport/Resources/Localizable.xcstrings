    "widget.today.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See today's open tasks at a glance."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一眼查看今天的待办任务。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die heutigen offenen Aufgaben auf einen Blick sehen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consulta de un vistazo tus tareas pendientes de hoy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualisez d'un coup d'œil vos tâches en cours du jour."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日の未完了タスクをひと目で確認できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘의 미완료 작업을 한눈에 확인하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja as tarefas pendentes de hoje rapidamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просматривайте сегодняшние открытые задачи с одного взгляда."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一眼查看今天的待辦任務。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vedi a colpo d'occhio le attività aperte di oggi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprawdź dzisiejsze otwarte zadania na pierwszy rzut oka."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bugünün açık görevlerini bir bakışta görün."
          }
        }
      }
    },

    "settings.mcp.ready_blurb": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex enthält ein integriertes Hilfsprogramm, damit dein Assistent deine Aufgaben lesen und aktualisieren kann. Füge es mit den Verbindungsdetails oben hinzu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex includes a built-in helper so your assistant can read and update your tasks. Add it using the connection details above."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex incluye un asistente integrado para que tu asistente pueda leer y actualizar tus tareas. Añádelo con los datos de conexión de arriba."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex inclut un utilitaire intégré pour que votre assistant puisse lire et mettre à jour vos tâches. Ajoutez-le à l’aide des détails de connexion ci-dessus."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex include un helper integrato così il tuo assistente può leggere e aggiornare le tue attività. Aggiungilo usando i dettagli di connessione qui sopra."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex には内蔵ヘルパーが含まれており、アシスタントがタスクを読み取って更新できます。上の接続情報を使って追加してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex에는 내장 도우미가 포함되어 있어 어시스턴트가 작업을 읽고 업데이트할 수 있습니다. 위의 연결 정보를 사용하여 추가하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex zawiera wbudowany moduł pomocniczy, dzięki któremu asystent może odczytywać i aktualizować zadania. Dodaj go, korzystając z danych połączenia powyżej."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lorvex inclui um auxiliar integrado para que o seu assistente possa ler e atualizar as suas tarefas. Adicione-o usando os detalhes de ligação acima."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В Lorvex встроен помощник, чтобы ваш ассистент мог читать и обновлять задачи. Добавьте его, используя данные подключения выше."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex, asistanınızın görevlerinizi okuyup güncelleyebilmesi için yerleşik bir yardımcı içerir. Yukarıdaki bağlantı bilgilerini kullanarak ekleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 内置了帮助程序，让你的助手可以读取和更新你的任务。使用上方的连接信息添加它。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 內建了輔助程式，讓你的助理可以讀取和更新你的任務。使用上方的連線資訊新增它。"
          }
        }
      }
    },

    "system.task.recurrence.exception.add.description": {
      "comment": "Description for the Add Lorvex Recurrence Exception App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Wiederholungsdatum einer wiederkehrenden Lorvex-Aufgabe überspringen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skip one occurrence date for a recurring Lorvex task."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Omite una fecha de repetición de una tarea recurrente de Lorvex."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ignorez une date d'occurrence d'une tâche Lorvex récurrente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salta una data di occorrenza per un'attività Lorvex ricorrente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "繰り返し Lorvex タスクの発生日を 1 つスキップします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "반복되는 Lorvex 작업의 발생 날짜 하나를 건너뜁니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pomiń jedną datę wystąpienia dla powtarzającego się zadania Lorvex."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pula uma data de ocorrência de uma tarefa recorrente do Lorvex."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пропустить одну дату повторения для повторяющейся задачи Lorvex."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yinelenen bir Lorvex görevi için bir tekrar tarihini atla."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "跳过一个周期性 Lorvex 任务的某次发生日期。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "略過週期性 Lorvex 任務的某次發生日期。"
          }
        }
      }
    },

    "settings.reset.delete_failed": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Löschen der lokalen Daten konnte nicht abgeschlossen werden. Starte Lorvex neu und versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t finish erasing local data. Restart Lorvex and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo terminar de borrar los datos locales. Reinicia Lorvex e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de terminer l’effacement des données locales. Redémarrez Lorvex et réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile completare la cancellazione dei dati locali. Riavvia Lorvex e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルデータの消去を完了できませんでした。Lorvex を再起動して、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬 데이터 지우기를 완료하지 못했습니다. Lorvex를 재시작하고 다시 시도하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się dokończyć wymazywania danych lokalnych. Uruchom Lorvex ponownie i spróbuj jeszcze raz."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível concluir a exclusão dos dados locais. Reinicie o Lorvex e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось завершить удаление локальных данных. Перезапустите Lorvex и повторите попытку."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yerel verileri silme işlemi tamamlanamadı. Lorvex’i yeniden başlatıp tekrar deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法完成本地数据清除。请重新启动 Lorvex 后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法完成本機資料清除。請重新啟動 Lorvex 後再試一次。"
          }
        }
      }
    },
    "settings.reset.detail": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Von Lorvex verwaltete lokale Daten und Einstellungen auf diesem Mac löschen und neu beginnen. Dies wirkt nur lokal: Bereits mit iCloud synchronisierte Daten bleiben in iCloud und können erneut geladen werden, sobald die Synchronisierung wieder aktiviert wird. Termine im Systemkalender werden nicht gelöscht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Erase Lorvex-managed local data and settings on this Mac and start fresh. This is local-only: data already synced to iCloud stays in iCloud and can download again when sync is re-enabled. System Calendar events are not deleted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Borra los datos locales y ajustes gestionados por Lorvex en este Mac y empieza de cero. Es solo local: los datos ya sincronizados con iCloud permanecen en iCloud y pueden volver a descargarse cuando se reactive la sincronización. Los eventos del Calendario del sistema no se eliminan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Efface les données locales et réglages gérés par Lorvex sur ce Mac et repart de zéro. Cette action est locale uniquement : les données déjà synchronisées avec iCloud restent dans iCloud et pourront être téléchargées à nouveau lorsque la synchronisation sera réactivée. Les événements du Calendrier système ne sont pas supprimés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancella i dati locali e le impostazioni gestiti da Lorvex su questo Mac e ricomincia da capo. È solo locale: i dati già sincronizzati con iCloud restano in iCloud e possono essere scaricati di nuovo quando la sincronizzazione viene riattivata. Gli eventi del Calendario di sistema non vengono eliminati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この Mac 上で Lorvex が管理するローカルデータと設定を消去して、最初からやり直します。この操作はローカルのみです。すでに iCloud に同期されたデータは iCloud に残り、同期を再度有効にすると再ダウンロードされることがあります。システムのカレンダーの予定は削除されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 Mac에서 Lorvex가 관리하는 로컬 데이터와 설정을 지우고 처음부터 다시 시작합니다. 이 작업은 로컬에만 적용됩니다. 이미 iCloud에 동기화된 데이터는 iCloud에 남아 있으며 동기화를 다시 켜면 다시 다운로드될 수 있습니다. 시스템 캘린더 이벤트는 삭제되지 않습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usuń zarządzane przez Lorvex dane lokalne i ustawienia na tym Macu i zacznij od nowa. Działa to tylko lokalnie: dane zsynchronizowane już z iCloud pozostają w iCloud i mogą zostać pobrane ponownie po ponownym włączeniu synchronizacji. Wydarzenia w Kalendarzu systemowym nie zostaną usunięte."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Apaga os dados locais e as configurações gerenciados pelo Lorvex neste Mac e começa do zero. É apenas local: os dados já sincronizados com o iCloud permanecem no iCloud e podem ser baixados novamente quando a sincronização for reativada. Eventos do Calendário do sistema não são excluídos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стирает управляемые Lorvex локальные данные и настройки на этом Mac и начинает заново. Это действует только локально: данные, уже синхронизированные с iCloud, остаются в iCloud и могут снова загрузиться при повторном включении синхронизации. События системного Календаря не удаляются."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu Mac’te Lorvex tarafından yönetilen yerel verileri ve ayarları siler ve sıfırdan başlar. Bu yalnızca yereldir: iCloud’a zaten eşitlenmiş veriler iCloud’da kalır ve eşitleme yeniden açıldığında tekrar indirilebilir. Sistem Takvimi etkinlikleri silinmez."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清除本台 Mac 上由 Lorvex 管理的本地数据和设置并重新开始。此操作仅限本地：已同步到 iCloud 的数据会保留在 iCloud 中，重新启用同步后可能会再次下载。系统日历中的事件不会被删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "清除這台 Mac 上由 Lorvex 管理的本機資料與設定並重新開始。此操作僅限本機：已同步至 iCloud 的資料會保留在 iCloud 中，重新啟用同步後可能會再次下載。系統行事曆中的活動不會被刪除。"
          }
        }
      }
    },
    "settings.reset.environment_database_error": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex verwendet einen Datenbankpfad aus der Startumgebung. Entferne diese Umgebungseinstellung und starte Lorvex neu, bevor du lokale Daten zurücksetzt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex is using a database path from the launch environment. Remove that environment setting and restart Lorvex before resetting local data."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex está usando una ruta de base de datos del entorno de inicio. Elimina esa configuración del entorno y reinicia Lorvex antes de restablecer los datos locales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex utilise un chemin de base de données issu de l’environnement de lancement. Supprimez ce réglage d’environnement et redémarrez Lorvex avant de réinitialiser les données locales."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex sta usando un percorso di database dall’ambiente di avvio. Rimuovi questa impostazione dell’ambiente e riavvia Lorvex prima di reimpostare i dati locali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex は起動環境で指定されたデータベースパスを使用しています。ローカルデータをリセットする前に、その環境設定を削除して Lorvex を再起動してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex가 실행 환경에 지정된 데이터베이스 경로를 사용하고 있습니다. 로컬 데이터를 재설정하기 전에 해당 환경 설정을 제거하고 Lorvex를 다시 시작하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex używa ścieżki bazy danych ze środowiska uruchomieniowego. Usuń to ustawienie środowiska i uruchom Lorvex ponownie przed zresetowaniem danych lokalnych."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lorvex está usando um caminho de banco de dados do ambiente de inicialização. Remova essa configuração de ambiente e reinicie o Lorvex antes de redefinir os dados locais."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex использует путь к базе данных из среды запуска. Удалите эту настройку среды и перезапустите Lorvex перед сбросом локальных данных."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex, başlatma ortamından gelen bir veritabanı yolunu kullanıyor. Yerel verileri sıfırlamadan önce bu ortam ayarını kaldırın ve Lorvex'i yeniden başlatın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 正在使用来自启动环境的数据库路径。请先移除该环境设置并重启 Lorvex，然后再重置本地数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 正在使用來自啟動環境的資料庫路徑。請先移除該環境設定並重新啟動 Lorvex，然後再重設本機資料。"
          }
        }
      }
    },

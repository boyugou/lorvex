    "habits.empty.no_active.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf ＋, um eine Gewohnheit zu beginnen, die du aufbauen möchtest."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap ＋ to start a habit you want to build."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca ＋ para iniciar un hábito que deseas desarrollar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur ＋ pour commencer une habitude que vous souhaitez développer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca ＋ per iniziare un'abitudine che vuoi costruire."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "＋をタップして習慣を追加しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "＋를 탭하여 쌓고 싶은 습관을 시작하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stuknij ＋, aby rozpocząć nawyk, który chcesz wyrobić."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque em ＋ para iniciar um hábito que deseja construir."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите ＋, чтобы начать привычку, которую хотите выработать."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Geliştirmek istediğiniz bir alışkanlık başlatmak için ＋'ya dokunun."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "轻点 ＋ 开始培养一个习惯。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "輕點 ＋ 開始培養一個習慣。"
          }
        }
      }
    },

          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bildirimlerde Görev Notlarını Göster"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在通知中显示任务备注"
          }
        },
        "zh-Hant": {

    "habits.detail.empty.description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle eine Gewohnheit, um ihren Fortschritt zu prüfen und den heutigen Abschluss zu aktualisieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose a habit to review its progress and update today's completion."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un hábito para revisar su progreso y actualizar el estado de hoy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une habitude pour examiner sa progression et mettre à jour son achèvement du jour."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli un'abitudine per esaminarne i progressi e aggiornare il completamento di oggi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "習慣を選んで進捗を確認し、今日の達成状況を更新します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "습관을 선택해 진행 상황을 확인하고 오늘의 완료 상태를 업데이트하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz nawyk, aby przejrzeć jego postępy i zaktualizować dzisiejsze ukończenie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha um hábito para revisar o progresso e atualizar a conclusão de hoje."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите привычку, чтобы просмотреть её прогресс и обновить выполнение за сегодня."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İlerlemesini incelemek ve bugünkü tamamlamayı güncellemek için bir alışkanlık seçin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择一个习惯，以查看进度并更新今天的完成情况。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇一個習慣，以檢視進度並更新今天的完成情況。"
          }
        }
      }
    },

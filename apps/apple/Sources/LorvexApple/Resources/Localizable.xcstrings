    "settings.data_import.error.busy": {
      "extractionState": "manual",
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Ein anderer Import- oder Datenvorgang läuft noch. Warte, bis er abgeschlossen ist, und versuche es dann erneut." } },
        "en": { "stringUnit": { "state": "translated", "value": "Another import or data operation is still running. Wait for it to finish, then try again." } },
        "es": { "stringUnit": { "state": "translated", "value": "Todavía hay otra importación u operación de datos en curso. Espera a que termine y vuelve a intentarlo." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Une autre importation ou opération sur les données est toujours en cours. Attendez qu’elle se termine, puis réessayez." } },
        "it": { "stringUnit": { "state": "translated", "value": "È ancora in corso un’altra importazione o operazione sui dati. Attendi che termini, quindi riprova." } },
        "ja": { "stringUnit": { "state": "translated", "value": "別の読み込みまたはデータ操作が実行中です。完了してから、もう一度お試しください。" } },
        "ko": { "stringUnit": { "state": "translated", "value": "다른 가져오기 또는 데이터 작업이 아직 진행 중입니다. 완료될 때까지 기다린 후 다시 시도하십시오." } },
        "pl": { "stringUnit": { "state": "translated", "value": "Nadal trwa inny import lub operacja na danych. Poczekaj na zakończenie i spróbuj ponownie." } },
        "pt": { "stringUnit": { "state": "translated", "value": "Outra importação ou operação de dados ainda está em andamento. Aguarde a conclusão e tente novamente." } },
        "ru": { "stringUnit": { "state": "translated", "value": "Другой импорт или операция с данными ещё выполняется. Дождитесь завершения и повторите попытку." } },
        "tr": { "stringUnit": { "state": "translated", "value": "Başka bir içe aktarma veya veri işlemi hâlâ sürüyor. Tamamlanmasını bekleyip tekrar deneyin." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "另一项导入或数据操作仍在进行中。请等待其完成后重试。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "另一項匯入或資料操作仍在進行中。請等待完成後再試一次。" } }
      }
    },
    "settings.data_import.error.cloud_sync_not_ready": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex konnte die neuesten iCloud-Daten nicht überprüfen. Daher wurde das Backup nicht importiert. Stelle sicher, dass du bei iCloud angemeldet bist und Cloud-Synchronisierung bereit ist, und versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex couldn’t verify the latest iCloud data, so the backup wasn’t imported. Make sure iCloud is signed in and Cloud Sync is ready, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex no pudo verificar los datos más recientes de iCloud, por lo que no se importó la copia de seguridad. Asegúrate de haber iniciado sesión en iCloud y de que la sincronización esté lista, e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex n’a pas pu vérifier les données iCloud les plus récentes. La sauvegarde n’a donc pas été importée. Vérifiez que vous êtes connecté à iCloud et que la synchronisation est prête, puis réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex non ha potuto verificare i dati iCloud più recenti, quindi il backup non è stato importato. Assicurati di aver effettuato l’accesso a iCloud e che la sincronizzazione sia pronta, quindi riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最新のiCloudデータを確認できなかったため、バックアップは読み込まれませんでした。iCloudにサインインし、Cloud同期の準備ができていることを確認して、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최신 iCloud 데이터를 확인할 수 없어 백업을 가져오지 않았습니다. iCloud에 로그인되어 있고 Cloud 동기화가 준비되었는지 확인한 후 다시 시도하십시오."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex nie mógł zweryfikować najnowszych danych iCloud, dlatego kopia zapasowa nie została zaimportowana. Upewnij się, że zalogowano się do iCloud i synchronizacja jest gotowa, a następnie spróbuj ponownie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lorvex não conseguiu verificar os dados mais recentes do iCloud, por isso o backup não foi importado. Confirme que a sessão do iCloud está iniciada e que a sincronização está pronta, depois tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex не удалось проверить последние данные iCloud, поэтому резервная копия не была импортирована. Убедитесь, что выполнен вход в iCloud и синхронизация готова, затем повторите попытку."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex en son iCloud verilerini doğrulayamadığı için yedek içe aktarılmadı. iCloud’a giriş yapıldığından ve Cloud eşzamanlamanın hazır olduğundan emin olup tekrar deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 无法验证最新的 iCloud 数据，因此未导入备份。请确认已登录 iCloud 且云同步已就绪，然后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 無法驗證最新的 iCloud 資料，因此未匯入備份。請確認已登入 iCloud 且雲端同步已就緒，然後再試一次。"
          }
        }
      }
    },
    "settings.data_import.description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lade Daten aus einer JSON- oder ZIP-Datei, die du oben mit Exportieren erstellt hast. Du siehst zuerst, was die Datei enthält; beim Import werden bereits vorhandene Daten nie dupliziert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Load data from a JSON or ZIP file you made with Export above. You'll see what the file contains first; importing never duplicates data you already have."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Carga datos desde un archivo JSON o ZIP que creaste con Exportar más arriba. Primero verás lo que contiene el archivo; al importar nunca se duplican los datos que ya tienes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chargez des données depuis un fichier JSON ou ZIP créé avec Exporter ci-dessus. Vous verrez d'abord ce que contient le fichier ; l'importation ne duplique jamais les données que vous avez déjà."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Carica i dati da un file JSON o ZIP creato con Esporta qui sopra. Vedrai prima cosa contiene il file; l'importazione non duplica mai i dati che hai già."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "上の「書き出す」で作成した JSON または ZIP ファイルからデータを読み込みます。まずファイルの内容が表示され、読み込んでも既存のデータが重複することはありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "위의 내보내기로 만든 JSON 또는 ZIP 파일에서 데이터를 가져옵니다. 먼저 파일에 담긴 내용을 보여주며, 가져와도 이미 있는 데이터가 중복되지 않습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wczytaj dane z pliku JSON lub ZIP utworzonego powyżej przez Eksport. Najpierw zobaczysz, co zawiera plik; import nigdy nie duplikuje danych, które już masz."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Carregue dados de um arquivo JSON ou ZIP que você criou com Exportar acima. Você verá primeiro o que o arquivo contém; a importação nunca duplica dados que você já tem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Загрузите данные из файла JSON или ZIP, созданного с помощью «Экспорта» выше. Сначала вы увидите, что содержит файл; импорт никогда не дублирует данные, которые у вас уже есть."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yukarıdaki Dışa Aktar ile oluşturduğunuz bir JSON veya ZIP dosyasından veri yükleyin. Önce dosyanın ne içerdiğini görürsünüz; içe aktarma, zaten sahip olduğunuz verileri asla çoğaltmaz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从你用上方“导出”创建的 JSON 或 ZIP 文件加载数据。你会先看到文件包含的内容；导入绝不会重复你已有的数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從你用上方「輸出」建立的 JSON 或 ZIP 檔案載入資料。你會先看到檔案包含的內容；匯入絕不會重複你已有的資料。"
          }
        }
      }
    },

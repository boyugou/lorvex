        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 동기화 모드는 Lorvex를 다시 시작하면 완전히 적용됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybrany tryb synchronizacji zacznie w pełni działać po ponownym uruchomieniu Lorvex."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O modo de sincronização selecionado terá efeito completo após reiniciar o Lorvex."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбранный режим синхронизации полностью вступит в силу после перезапуска Lorvex."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seçilen eşitleme modu, Lorvex yeniden başlatıldıktan sonra tamamen etkinleşir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所选同步模式将在重启 Lorvex 后完全生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "所選的同步模式將在重新啟動 Lorvex 後完全生效。"
          }
        }
      }
    },
    "settings.cloud_sync.restart_notice": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Änderungen werden nach einem Neustart der App wirksam."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Changes take effect after restarting the app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los cambios surten efecto después de reiniciar la app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les modifications prennent effet après le redémarrage de l'app."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le modifiche avranno effetto dopo il riavvio dell'app."
          }

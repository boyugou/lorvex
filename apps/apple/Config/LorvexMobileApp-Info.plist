<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>Lorvex</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>com.lorvex.apple</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>de</string>
		<string>en</string>
		<string>es</string>
		<string>fr</string>
		<string>it</string>
		<string>ja</string>
		<string>ko</string>
		<string>pl</string>
		<string>pt</string>
		<string>ru</string>
		<string>tr</string>
		<string>zh-Hans</string>
		<string>zh-Hant</string>
	</array>
	<key>CFBundleName</key>
	<string>LorvexMobileApp</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>2</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.lorvex.apple</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>lorvex</string>
			</array>
		</dict>
	</array>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.productivity</string>
	<key>MinimumOSVersion</key>
	<string>18.0</string>
	<!--
	A launch screen is mandatory for the app to render at the device's native
	resolution. Without UILaunchScreen, iOS runs the app in legacy compatibility
	mode — letterboxed at a smaller logical size with black bars top and bottom —
	which confines every view and sheet to a reduced frame (clipping content like
	the onboarding call-to-action). An empty dict gives a blank system-background
	launch screen, which is all that is needed to opt into full-screen rendering.
	-->
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>NSUserActivityTypes</key>
	<array>
		<string>com.lorvex.apple.openTask</string>
		<string>com.lorvex.apple.openDestination</string>
		<string>com.lorvex.apple.openList</string>
	</array>
	<!--
	CarPlay activation template.

	Do not uncomment this block until Apple approves the CarPlay entitlement
	for the Lorvex iOS App ID and Config/LorvexCarPlay.entitlements has been
	merged into the signed app target. Without the portal capability, enabling
	the scene keys causes signing/App Store validation failures.

	<key>CPSupportsTemplateApplicationScene</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UISceneConfigurations</key>
		<dict>
			<key>CPTemplateApplicationSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>CPTemplateApplicationScene</string>
					<key>UISceneDelegateClassName</key>
					<string>LorvexCarPlay.LorvexCarPlaySceneDelegate</string>
				</dict>
			</array>
		</dict>
	</dict>
	-->
	<key>UIApplicationShortcutItems</key>
	<array>
		<dict>
			<key>UIApplicationShortcutItemType</key>
			<string>com.lorvex.apple.quickCapture</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Quick Capture</string>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>square.and.pencil</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemType</key>
			<string>com.lorvex.apple.openToday</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Open Today</string>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>sun.max</string>
		</dict>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.lorvex.apple.reminder-refresh</string>
	</array>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>Lorvex can read event details to build schedules and assistant context.</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>

          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Некоторые записи не удалось синхронизировать; может потребоваться полная повторная синхронизация."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",

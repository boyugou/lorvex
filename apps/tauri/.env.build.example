# Build credentials for code signing and notarization.
# Copy to `.env.build` and fill in real values.
# `.env.build` is gitignored — never commit credentials.
#
# Audit #2931-L1: this example mirrors the secret set the macOS release build
# tooling consumes for code signing and notarization, so a developer
# reproducing that signing flow locally has parity.

# ── macOS (Apple code signing + notarization) ────────────────────────────
export APPLE_SIGNING_IDENTITY=""   # SHA-1 hash of your Developer ID certificate
export APPLE_ID=""                 # Your Apple ID email
export APPLE_PASSWORD=""           # App-specific password (appleid.apple.com -> App-Specific Passwords)
export APPLE_TEAM_ID=""            # Your Apple Developer Team ID

# ── macOS keychain bootstrap (matches CI's `Import Apple certificate` step) ──
# Required only when reproducing the CI keychain-import flow locally.
# Local builds normally skip this and use the existing login keychain.
export APPLE_CERTIFICATE=""           # Base64-encoded .p12 of the Developer ID certificate
export APPLE_CERTIFICATE_PASSWORD=""  # Password protecting the .p12 above

# ── Tauri updater signing (.sig generation for auto-update payloads) ─────
# Required for `tauri build` when the updater is enabled (it is — see
# tauri.conf.json#bundle.updater). CI injects these via secrets; local
# devs only need them to test the updater chain end-to-end.
export TAURI_SIGNING_PRIVATE_KEY=""           # Base64 minisign private key, generated by `tauri signer generate`
export TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""  # Required password protecting the key above

# ── Windows (Authenticode code signing) ──────────────────────────────────
# Tauri's NSIS bundler reads certificateThumbprint from tauri.conf.json,
# but you can also use a custom signCommand for more control.
#
# Option A: Certificate thumbprint (requires cert installed in Windows cert store)
export WINDOWS_CERTIFICATE_THUMBPRINT=""  # SHA-1 thumbprint of your Authenticode certificate
#
# Option B: PFX file (alternative to cert store) — also the form CI uses
export WINDOWS_CERTIFICATE=""             # Base64-encoded .pfx (CI form: `[Convert]::ToBase64String(...)`)
export WINDOWS_CERTIFICATE_FILE=""        # Path to .pfx file (local form, alternative to base64)
export WINDOWS_CERTIFICATE_PASSWORD=""    # Password for the .pfx file

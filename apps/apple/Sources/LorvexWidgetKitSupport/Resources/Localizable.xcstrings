    "widget.progress.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track today's task completion at a glance."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一眼追踪今天的任务完成情况。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfolge die heutige Aufgabenerledigung auf einen Blick."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consulta de un vistazo cuántas tareas de hoy has completado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez d’un coup d’œil l’avancement de vos tâches du jour."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日のタスク完了状況を一目で確認できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘의 작업 완료 상황을 한눈에 확인하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Acompanhe num relance a conclusão das tarefas de hoje."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отслеживайте выполнение задач за сегодня одним взглядом."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一眼追蹤今天的任務完成情況。"
          }
        },
        "it": {
          "stringUnit": {

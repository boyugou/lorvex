<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ExportOptions for App Store Connect distribution of the watchOS target.

  Required environment:
    APPLE_TEAM_ID   — 10-character Apple Developer Team ID (e.g. ABCDE12345)

  Replace TEAM_ID_PLACEHOLDER with the actual value, or use
  archive_ios.sh which performs the substitution automatically.

  A watchOS app must be embedded inside its companion iOS app for App Store
  distribution. Archiving LorvexWatchApp as a standalone scheme produces a
  watchOS-only archive suitable for direct device install via Xcode; it cannot
  be submitted to App Store Connect independently. See docs/DISTRIBUTION.md §4.

  method: "app-store-connect" is the current Xcode 15+ key.
  destination: "export" produces an artifact suitable for App Store Connect upload.
-->
<plist version="1.0">
<dict>
  <key>method</key>
  <string>app-store-connect</string>
  <key>destination</key>
  <string>export</string>
  <key>teamID</key>
  <string>TEAM_ID_PLACEHOLDER</string>
  <key>signingStyle</key>
  <string>automatic</string>
  <key>uploadSymbols</key>
  <true/>
  <key>stripSwiftSymbols</key>
  <true/>
  <key>compileBitcode</key>
  <false/>
</dict>
</plist>

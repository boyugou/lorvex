    "widget.habits.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See today's habit progress at a glance."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一眼查看今天的习惯进度。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Den heutigen Gewohnheitsfortschritt auf einen Blick sehen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consulta de un vistazo el progreso de tus hábitos de hoy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualisez d'un coup d'œil la progression de vos habitudes du jour."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日の習慣の進捗をひと目で確認できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘의 습관 진행 상황을 한눈에 확인하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja o progresso dos hábitos de hoje rapidamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просматривайте сегодняшний прогресс по привычкам с одного взгляда."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一眼查看今天的習慣進度。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vedi a colpo d'occhio i progressi delle abitudini di oggi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprawdź dzisiejsze postępy nawyków na pierwszy rzut oka."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bugünün alışkanlık ilerlemesini bir bakışta görün."
          }
        }
      }
    },

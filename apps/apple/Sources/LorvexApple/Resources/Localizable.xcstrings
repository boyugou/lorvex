    "settings.calendar.access.scope_detail": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gilt für das, was Lorvex und verbundene Assistenten auf diesem Gerät sehen können."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Applies to what Lorvex and connected assistants can see on this device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se aplica a lo que Lorvex y los asistentes conectados pueden ver en este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "S’applique à ce que Lorvex et les assistants connectés peuvent voir sur cet appareil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si applica a ciò che Lorvex e gli assistenti connessi possono vedere su questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスで Lorvex と接続中のアシスタントに表示される内容に適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기에서 Lorvex와 연결된 어시스턴트가 볼 수 있는 내용에 적용됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dotyczy informacji widocznych dla Lorvex i połączonych asystentów na tym urządzeniu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplica-se ao que o Lorvex e os assistentes conectados podem ver neste dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Определяет, что могут видеть Lorvex и подключённые ассистенты на этом устройстве."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex ve bağlı asistanların bu aygıtta görebileceği içeriklere uygulanır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "适用于 Lorvex 和已连接的助手可在此设备上看到的内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "適用於 Lorvex 和已連線的助理可在此裝置上看到的內容。"
          }
        }
      }
    },
    "settings.calendar.access_denied": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Kalenderzugriff wurde verweigert. Öffne die Systemeinstellungen, um den Zugriff zu gewähren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calendar access has been denied. Open System Settings to grant access."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se ha denegado el acceso al calendario. Abre Ajustes del Sistema para concederlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès au calendrier a été refusé. Ouvrez Réglages Système pour l'autoriser."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accesso al calendario è stato negato. Apri Impostazioni di Sistema per concedere l'accesso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カレンダーへのアクセスが拒否されました。「システム設定」を開いてアクセスを許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캘린더 접근이 거부되었습니다. 시스템 설정을 열어 접근을 허용하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odmówiono dostępu do kalendarza. Otwórz Ustawienia systemowe, aby przyznać dostęp."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso ao calendário foi negado. Abra os Ajustes do Sistema para conceder o acesso."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ к календарю отклонён. Откройте «Системные настройки», чтобы предоставить доступ."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Takvim erişimi reddedildi. Erişim izni vermek için Sistem Ayarları'nı açın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "日历访问已被拒绝。请打开“系统设置”授予访问权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "行事曆存取已遭拒。請開啟「系統設定」以授予存取權。"
          }
        }
      }
    },

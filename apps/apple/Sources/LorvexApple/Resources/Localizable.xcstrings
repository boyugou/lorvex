    "settings.cloud_sync.mode.off_detail": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud-Synchronisierung ist deaktiviert. Es werden keine Daten an CloudKit gesendet oder von dort abgerufen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud sync is disabled. No data is pushed to or pulled from CloudKit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La sincronización con iCloud está desactivada. No se envían ni se reciben datos de CloudKit."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La synchronisation iCloud est désactivée. Aucune donnée n’est envoyée à CloudKit ni récupérée depuis CloudKit."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La sincronizzazione iCloud è disattivata. Nessun dato viene inviato a CloudKit o recuperato da esso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 同期は無効です。CloudKit へのデータの送信も取得も行われません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 동기화가 비활성화되어 있습니다. CloudKit으로 데이터를 보내거나 가져오지 않습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchronizacja iCloud jest wyłączona. Żadne dane nie są wysyłane do CloudKit ani z niego pobierane."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A sincronização com iCloud está desativada. Nenhum dado é enviado ao CloudKit nem recebido dele."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Синхронизация с iCloud отключена. Данные не отправляются в CloudKit и не извлекаются из него."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud eşitlemesi devre dışı. CloudKit'e veri gönderilmez veya CloudKit'ten veri çekilmez."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 同步已关闭。不会向 CloudKit 推送或拉取任何数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 同步已停用。不會向 CloudKit 推送或從中拉取任何資料。"
          }
        }
      }
    },

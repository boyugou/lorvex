    "recurrence.editor.error.concurrent_change": {
      "extractionState": "manual",
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Diese Wiederholung wurde auf einem anderen Gerät geändert, während du sie bearbeitet hast. Prüfe die aktuelle Regel und versuche es erneut." } },
        "en": { "stringUnit": { "state": "translated", "value": "This recurrence changed on another device while you were editing. Review the latest rule and try again." } },
        "es": { "stringUnit": { "state": "translated", "value": "Esta repetición cambió en otro dispositivo mientras la editabas. Revisa la regla actual e inténtalo de nuevo." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Cette récurrence a été modifiée sur un autre appareil pendant votre modification. Vérifiez la règle actuelle et réessayez." } },
        "it": { "stringUnit": { "state": "translated", "value": "Questa ricorrenza è stata modificata su un altro dispositivo mentre la stavi modificando. Controlla la regola attuale e riprova." } },
        "ja": { "stringUnit": { "state": "translated", "value": "編集中に別のデバイスでこの繰り返しが変更されました。最新のルールを確認して、もう一度お試しください。" } },
        "ko": { "stringUnit": { "state": "translated", "value": "편집하는 동안 다른 기기에서 이 반복 규칙이 변경되었습니다. 최신 규칙을 확인한 후 다시 시도하세요." } },
        "pl": { "stringUnit": { "state": "translated", "value": "Podczas edycji ta reguła powtarzania została zmieniona na innym urządzeniu. Sprawdź aktualną regułę i spróbuj ponownie." } },
        "pt": { "stringUnit": { "state": "translated", "value": "Esta recorrência foi alterada noutro dispositivo enquanto a editava. Reveja a regra atual e tente novamente." } },
        "ru": { "stringUnit": { "state": "translated", "value": "Во время редактирования это повторение было изменено на другом устройстве. Проверьте актуальное правило и повторите попытку." } },
        "tr": { "stringUnit": { "state": "translated", "value": "Siz düzenlerken bu yineleme başka bir aygıtta değiştirildi. Güncel kuralı gözden geçirip yeniden deneyin." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "你编辑期间，此重复规则已在另一台设备上更改。请检查最新规则后重试。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "你編輯期間，此重複規則已在另一部裝置上變更。請檢查最新規則後再試一次。" } }
      }
    },
    "recurrence.editor.error.invalid_interval": {
      "extractionState": "manual",
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Das Wiederholungsintervall muss eine ganze Zahl zwischen 1 und 10.000 sein." } },
        "en": { "stringUnit": { "state": "translated", "value": "The recurrence interval must be a whole number from 1 through 10,000." } },
        "es": { "stringUnit": { "state": "translated", "value": "El intervalo de repetición debe ser un número entero entre 1 y 10.000." } },
        "fr": { "stringUnit": { "state": "translated", "value": "L’intervalle de récurrence doit être un nombre entier compris entre 1 et 10 000." } },
        "it": { "stringUnit": { "state": "translated", "value": "L’intervallo di ricorrenza deve essere un numero intero compreso tra 1 e 10.000." } },
        "ja": { "stringUnit": { "state": "translated", "value": "繰り返し間隔は1〜10,000の整数にしてください。" } },
        "ko": { "stringUnit": { "state": "translated", "value": "반복 간격은 1에서 10,000 사이의 정수여야 합니다." } },
        "pl": { "stringUnit": { "state": "translated", "value": "Interwał powtarzania musi być liczbą całkowitą od 1 do 10 000." } },
        "pt": { "stringUnit": { "state": "translated", "value": "O intervalo de recorrência tem de ser um número inteiro entre 1 e 10 000." } },
        "ru": { "stringUnit": { "state": "translated", "value": "Интервал повторения должен быть целым числом от 1 до 10 000." } },
        "tr": { "stringUnit": { "state": "translated", "value": "Yineleme aralığı 1 ile 10.000 arasında bir tam sayı olmalıdır." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "重复间隔必须是 1 到 10,000 之间的整数。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "重複間隔必須是 1 到 10,000 之間的整數。" } }
      }
    },
    "recurrence.anchor.completion": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "After completion" } },
        "de": { "stringUnit": { "state": "translated", "value": "Nach Abschluss" } },
        "es": { "stringUnit": { "state": "translated", "value": "Tras completar" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Après achèvement" } },
        "it": { "stringUnit": { "state": "translated", "value": "Dopo il completamento" } },
        "ja": { "stringUnit": { "state": "translated", "value": "完了後" } },
        "ko": { "stringUnit": { "state": "translated", "value": "완료 후" } },
        "pl": { "stringUnit": { "state": "translated", "value": "Po ukończeniu" } },
        "pt": { "stringUnit": { "state": "translated", "value": "Após concluir" } },
        "ru": { "stringUnit": { "state": "translated", "value": "После выполнения" } },
        "tr": { "stringUnit": { "state": "translated", "value": "Tamamlandıktan sonra" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "完成后" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "完成後" } }
      }
    },
    "recurrence.anchor.completion.hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The next one is scheduled relative to when you complete this, so a late finish pushes it forward."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der nächste Termin richtet sich danach, wann du dies abschließt – ein späterer Abschluss verschiebt ihn nach hinten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La siguiente se programa en función de cuándo completes esta, así que terminar tarde la desplaza hacia adelante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La prochaine est planifiée en fonction du moment où vous terminez celle-ci ; un achèvement tardif la décale d'autant."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La prossima viene pianificata in base a quando completi questa, quindi un completamento in ritardo la sposta in avanti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次回はこのタスクを完了したタイミングを基準に予定されるため、完了が遅れるとその分先に延びます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다음 항목은 이 작업을 완료한 시점을 기준으로 예약되므로, 늦게 완료하면 그만큼 뒤로 밀립니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Następne zadanie jest planowane względem momentu ukończenia tego, więc późniejsze zakończenie przesuwa je do przodu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A próxima é agendada em relação a quando você concluir esta, então terminar tarde a empurra para frente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Следующее планируется относительно момента выполнения этого, поэтому позднее завершение сдвигает его вперёд."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sonraki, bunu tamamladığınız ana göre planlanır; bu nedenle geç bitirmek onu ileri kaydırır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下一个会以你完成这一个的时间为基准来安排，因此完成得越晚，下一个就顺延得越晚。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "下一個會以你完成這一個的時間為基準來安排，因此完成得越晚，下一個就順延得越晚。"
          }
        }
      }
    },

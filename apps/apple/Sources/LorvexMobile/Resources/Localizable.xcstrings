    "setup.welcome.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein KI-nativer Planer – erfasse Aufgaben blitzschnell, plane deinen Tag und bleibe auf all deinen Apple-Geräten synchron."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your AI-native planner — capture tasks in a tap, plan your day, and stay in sync across your Apple devices."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu planificador nativo de IA: captura tareas al instante, planifica tu día y mantén todo sincronizado en tus dispositivos Apple."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre planificateur natif IA — capturez vos tâches en un geste, organisez votre journée et restez synchronisé sur tous vos appareils Apple."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo planner nativo per l'IA: cattura le attività al volo, pianifica la giornata e resta sincronizzato su tutti i tuoi dispositivi Apple."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AIネイティブのプランナー。タスクをすばやく記録し、一日を計画し、すべてのAppleデバイスで同期できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 네이티브 플래너입니다. 작업을 빠르게 기록하고, 하루를 계획하고, 모든 Apple 기기에서 동기화하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twój planer natywny dla AI — błyskawicznie zapisuj zadania, planuj dzień i zachowaj synchronizację na wszystkich urządzeniach Apple."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu planejador nativo de IA — capture tarefas num toque, planeje o seu dia e mantenha tudo sincronizado nos seus dispositivos Apple."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваш AI-native планировщик — мгновенно фиксируйте задачи, планируйте день и оставайтесь синхронизированными на всех устройствах Apple."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yapay zekâ doğasına sahip planlayıcınız — görevleri anında yakalayın, gününüzü planlayın ve tüm Apple cihazlarınızda eşitlenin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 AI 原生规划工具——轻点即可记录任务、规划每一天，并在所有 Apple 设备间保持同步。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 AI 原生規劃工具——輕點即可記錄任務、規劃每一天，並在所有 Apple 裝置間保持同步。"
          }
        }
      }
    },

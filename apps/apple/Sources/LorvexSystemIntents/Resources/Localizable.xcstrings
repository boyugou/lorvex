{
  "sourceLanguage": "en",
  "strings": {
    "system.ai_changelog.read.description": {
      "comment": "Description for the Read Lorvex AI Changelog App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktuelle Lorvex-KI-Änderungsprotokolleinträge über Kurzbefehle oder Siri lesen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read recent Lorvex AI changelog entries from Shortcuts or Siri."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee las entradas recientes del registro de cambios de la IA de Lorvex desde Atajos o Siri."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lire les entrées récentes du journal des modifications de l'IA Lorvex depuis Raccourcis ou Siri."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Leggi le voci recenti del changelog IA Lorvex da Comandi rapidi o Siri."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットまたは Siri から最近の Lorvex AI 変更履歴エントリを読み取ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축어 또는 Siri에서 최근 Lorvex AI 변경 기록 항목을 읽습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odczytaj ostatnie wpisy dziennika zmian AI Lorvex ze Skrótów lub Siri."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Lê as entradas recentes do registro de alterações da IA do Lorvex pelos Atalhos ou pela Siri."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чтение последних записей журнала изменений ИИ Lorvex из «Быстрых команд» или Siri."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısayollar veya Siri ile son Lorvex AI değişiklik günlüğü girişlerini oku."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从“快捷指令”或 Siri 读取最近的 Lorvex AI 变更记录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從「捷徑」或 Siri 讀取最近的 Lorvex AI 變更記錄。"
          }
        }
      }
    },
    "system.ai_changelog.read.dialog": {
      "comment": "Dialog after reading AI changelog; %lld is entry count and %@ is summary",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld Changelog-Eintrag. %2$@"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld Changelog-Einträge. %2$@"
                }
              }
            }
          }
        },
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld changelog entry. %2$@"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld changelog entries. %2$@"
                }
              }
            }
          }
        },
        "es": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld entrada del registro de cambios. %2$@"

    "list_row.delete.archived_nonempty_message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Liste kann nicht gelöscht werden, solange sie noch Aufgaben enthält. Hebe die Archivierung auf, um die Liste und ihre Aufgaben wiederherzustellen, und verschiebe oder lösche sie, bevor du die Liste löschst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This list can't be deleted while it still holds tasks. Unarchive it to restore the list and its tasks, then move or clear them before deleting it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta lista no se puede eliminar mientras siga conteniendo tareas. Desarchívala para restaurar la lista y sus tareas y, a continuación, muévelas o elimínalas antes de borrarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette liste ne peut pas être supprimée tant qu'elle contient des tâches. Désarchivez-la pour restaurer la liste et ses tâches, puis déplacez-les ou supprimez-les avant de la supprimer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa lista non può essere eliminata finché contiene attività. Ripristinala dall'archivio per recuperare la lista e le sue attività, quindi spostale o eliminale prima di cancellarla."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このリストにタスクが残っている間は削除できません。アーカイブを解除してリストとそのタスクを復元し、タスクを移動または削除してからリストを削除してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 목록에 작업이 남아 있는 동안에는 삭제할 수 없습니다. 보관을 해제하여 목록과 작업을 복원한 다음 작업을 옮기거나 지운 후 목록을 삭제하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tej listy nie można usunąć, dopóki zawiera zadania. Przywróć ją z archiwum, aby odzyskać listę i jej zadania, a następnie przenieś je lub usuń przed usunięciem listy."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta lista não pode ser excluída enquanto ainda contiver tarefas. Desarquive-a para restaurar a lista e suas tarefas e, em seguida, mova-as ou remova-as antes de excluí-la."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот список нельзя удалить, пока в нём есть задачи. Разархивируйте его, чтобы восстановить список и его задачи, затем переместите или удалите их, прежде чем удалять список."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu liste, içinde görevler bulunduğu sürece silinemez. Listeyi ve görevlerini geri yüklemek için arşivden çıkarın, ardından listeyi silmeden önce görevleri taşıyın veya temizleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此清单仍有任务时无法删除。请取消归档以恢复清单及其任务，然后移动或清除这些任务，再删除该清单。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此清單仍有任務時無法刪除。請取消封存以還原清單及其任務，然後移動或清除這些任務，再刪除該清單。"
          }
        }
      }
    },

    "settings.mcp.helper_blocked_detail": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das integrierte MCP-Hilfsprogramm von Lorvex ist nicht ausführbar. Installiere Lorvex aus dem Originaldownload neu oder hebe die Quarantäne auf, um die Verbindung wiederherzustellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex’s built-in MCP helper isn’t executable. Reinstall Lorvex from the original download, or remove it from quarantine, to restore the connection."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El asistente MCP integrado de Lorvex no es ejecutable. Reinstala Lorvex desde la descarga original o quítalo de la cuarentena para restaurar la conexión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’utilitaire MCP intégré de Lorvex n’est pas exécutable. Réinstallez Lorvex à partir du téléchargement d’origine ou retirez-le de la quarantaine pour rétablir la connexion."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L’helper MCP integrato di Lorvex non è eseguibile. Reinstalla Lorvex dal download originale o rimuovilo dalla quarantena per ripristinare la connessione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex の内蔵 MCP ヘルパーが実行可能ではありません。元のダウンロードから Lorvex を再インストールするか、検疫を解除して接続を復元してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex의 내장 MCP 도우미를 실행할 수 없습니다. 원본 다운로드에서 Lorvex를 다시 설치하거나 격리에서 해제하여 연결을 복원하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wbudowany moduł pomocniczy MCP aplikacji Lorvex nie jest wykonywalny. Zainstaluj ponownie Lorvex z oryginalnego pliku lub usuń go z kwarantanny, aby przywrócić połączenie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O auxiliar MCP integrado do Lorvex não é executável. Reinstale o Lorvex a partir do download original ou remova-o da quarentena para restaurar a conexão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встроенный помощник MCP в Lorvex не является исполняемым. Переустановите Lorvex из исходной загрузки или снимите его с карантина, чтобы восстановить подключение."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex’in yerleşik MCP yardımcısı çalıştırılabilir değil. Bağlantıyı geri yüklemek için Lorvex’i orijinal indirmeden yeniden yükleyin veya karantinadan çıkarın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 的内置 MCP 帮助程序不可执行。请从原始下载重新安装 Lorvex，或将其移出隔离区，以恢复连接。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 的內建 MCP 輔助程式無法執行。請從原始下載重新安裝 Lorvex，或將其移出隔離區，以還原連線。"
          }
        }
      }
    },
    "settings.mcp.helper_blocked_title": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",

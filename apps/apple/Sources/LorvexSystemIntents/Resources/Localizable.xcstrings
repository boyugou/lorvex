    "system.task.reopen.description": {
      "comment": "Description for the Reopen Lorvex Task App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffne eine abgeschlossene, abgebrochene oder zurückgestellte Lorvex-Aufgabe wieder."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reopen a completed, cancelled, or deferred Lorvex task."
          }

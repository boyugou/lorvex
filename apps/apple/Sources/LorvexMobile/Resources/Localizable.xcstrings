    "tasks.empty.cancelled.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abgebrochene Aufgaben bleiben hier sichtbar, damit alte Entscheidungen nachvollziehbar bleiben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancelled tasks stay visible here so old decisions remain inspectable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las tareas canceladas permanecen visibles aquí para que las decisiones antiguas sigan siendo consultables."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les tâches annulées restent visibles ici afin que les anciennes décisions restent consultables."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le attività annullate restano visibili qui, così le vecchie decisioni rimangono consultabili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャンセルしたタスクはここに表示され続けるため、過去の判断を後から確認できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "취소된 작업은 여기에 계속 표시되어 과거의 결정을 다시 확인할 수 있습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Anulowane zadania pozostają tu widoczne, aby stare decyzje można było przejrzeć."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As tarefas canceladas permanecem visíveis aqui para que decisões antigas possam ser revisadas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отменённые задачи остаются видны здесь, чтобы прежние решения можно было пересмотреть."
          }
        },
        "tr": {
          "stringUnit": {

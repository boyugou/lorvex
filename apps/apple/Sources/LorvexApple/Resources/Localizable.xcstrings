    "memory.workspace.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Woran sich der Assistent über Sie erinnert. Sie können auch Notizen hinzufügen oder bearbeiten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What the assistant remembers about you. You can add or edit notes too."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo que el asistente recuerda sobre ti. También puedes añadir o editar notas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce que l'assistant retient à votre sujet. Vous pouvez aussi ajouter ou modifier des notes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ciò che l'assistente ricorda di te. Puoi anche aggiungere o modificare note."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アシスタントがあなたについて覚えていること。メモの追加や編集もできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어시스턴트가 당신에 대해 기억하는 내용입니다. 메모를 추가하거나 편집할 수도 있습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To, co asystent pamięta o Tobie. Możesz też dodawać lub edytować notatki."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O que o assistente lembra sobre você. Você também pode adicionar ou editar notas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Что ассистент помнит о вас. Вы также можете добавлять и редактировать заметки."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Asistanın sizin hakkınızda hatırladıkları. Not da ekleyebilir veya düzenleyebilirsiniz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "助手记住的关于你的信息。你也可以添加或编辑笔记。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "助手記住的關於你的資訊。你也可以新增或編輯筆記。"
          }
        }
      }
    },

    "focus.schedule.clearConfirm.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernt die heutige Fokuszugehörigkeit und den Zeitblockplan. Aufgaben werden nicht gelöscht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes today's focus membership and time-block schedule. Tasks are not deleted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina la pertenencia al enfoque de hoy y el horario por bloques. Las tareas no se eliminan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime les tâches du focus du jour et le planning par blocs. Les tâches ne sont pas supprimées."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuove l’appartenenza al focus di oggi e la pianificazione a blocchi. Le attività non vengono eliminate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日のフォーカス対象と時間ブロックスケジュールを削除します。タスクは削除されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘의 집중 포함 항목과 시간 블록 일정을 제거합니다. 작업은 삭제되지 않습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usuwa dzisiejszą przynależność do skupienia i harmonogram bloków czasu. Zadania nie są usuwane."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso remove a seleção de foco de hoje e a agenda em blocos de tempo. As tarefas não são excluídas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это удалит сегодняшний фокус-набор и расписание блоков времени. Задачи не удаляются."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bugünün odak üyeliğini ve zaman bloklu programını kaldırır. Görevler silinmez."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会移除今天的专注成员和时间块日程。任务不会被删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這會移除今天的專注成員和時間區塊排程。任務不會被刪除。"
          }
        }
      }
    },

    "widget.control.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows the current focus task."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示当前专注任务。"

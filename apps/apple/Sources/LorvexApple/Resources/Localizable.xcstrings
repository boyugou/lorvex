    "settings.diagnostics.reseed_required.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einige Datensätze konnten nicht synchronisiert werden und benötigen möglicherweise eine vollständige Neusynchronisierung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some records could not be synced and may need a full re-sync."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algunos registros no se pudieron sincronizar y podrían necesitar una sincronización completa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Certains enregistrements n'ont pas pu être synchronisés et peuvent nécessiter une resynchronisation complète."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Alcuni record non sono stati sincronizzati e potrebbero richiedere una risincronizzazione completa."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一部のレコードを同期できませんでした。完全な再同期が必要な場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일부 레코드를 동기화하지 못했으며 전체 재동기화가 필요할 수 있습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niektórych rekordów nie udało się zsynchronizować i mogą wymagać pełnej ponownej synchronizacji."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",

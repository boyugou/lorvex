              }
            }
          }
        },
        "pl": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld wpis dziennika zmian. %2$@"
                }
              },
              "few": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld wpisy dziennika zmian. %2$@"
                }
              },
              "many": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld wpisów dziennika zmian. %2$@"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld wpisu dziennika zmian. %2$@"
                }
              }
            }
          }
        },
        "pt": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld entrada do registro de alterações. %2$@"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld entradas do registro de alterações. %2$@"
                }
              }
            }
          }
        },
        "ru": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld запись журнала изменений. %2$@"
                }
              },
              "few": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld записи журнала изменений. %2$@"
                }
              },
              "many": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld записей журнала изменений. %2$@"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld записи журнала изменений. %2$@"
                }
              }
            }
          }
        },
        "tr": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld değişiklik günlüğü girişi. %2$@"
                }
              }
            }
          }
        },
        "zh-Hans": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld 条变更记录。%2$@"
                }
              }
            }
          }
        },
        "zh-Hant": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld 條變更記錄。%2$@"
                }
              }
            }
          }
        }
      }
    },
    "system.ai_changelog.read.empty_summary": {
      "comment": "Summary used when there are no recent AI changelog entries",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine aktuellen KI-Änderungsprotokolleinträge."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No recent AI changelog entries."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin entradas recientes del registro de cambios de IA."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune entrée récente du journal des modifications IA."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuna voce recente del changelog IA."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最近の AI 変更履歴エントリはありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최근 AI 변경 로그 항목이 없습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Brak ostatnich wpisów dziennika zmian AI."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem entradas recentes do registro de alterações de IA."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет недавних записей журнала изменений ИИ."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Son AI değişiklik günlüğü girişi yok."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有最近的 AI 变更记录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "沒有最近的 AI 變更紀錄。"
          }
        }
      }
    },

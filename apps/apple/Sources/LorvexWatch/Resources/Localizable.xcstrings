    "watch.action.cancel.a11y": {
      "comment": "Accessibility label for the cancel-task button",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Wiederholung abbrechen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel occurrence"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancelar esta repetición"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Annuler cette occurrence"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Annulla questa occorrenza"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今回分のみキャンセル"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이번 회차만 취소"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Anuluj to wystąpienie"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancelar esta ocorrência"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отменить это повторение"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu tekrarı iptal et"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅取消本次"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅取消本次"
          }
        }
      }
    },
    "watch.action.cancel.confirm": {
      "comment": "Title of the cancel-task confirmation dialog; %@ is the task title",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Wiederholung von %@ abbrechen?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel this occurrence of %@?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cancelar esta repetición de %@?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Annuler cette occurrence de %@ ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Annullare questa occorrenza di %@?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ の今回分のみキャンセルしますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@의 이번 회차만 취소하시겠습니까?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Anulować to wystąpienie zadania %@?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancelar esta ocorrência de %@?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отменить это повторение задачи «%@»?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ için yalnızca bu tekrar iptal edilsin mi?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅取消“%@”的这一次？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅取消「%@」的這一次？"
          }
        }
      }
    },
    "watch.action.cancel.hint": {
      "comment": "Accessibility hint for cancelling a task; %@ is the task title",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bricht diese Wiederholung von %@ ab"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancels this occurrence of %@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancela esta repetición de %@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Annule cette occurrence de %@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Annulla questa occorrenza di %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ の今回分のみキャンセルします"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@의 이번 회차만 취소합니다"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Anuluje to wystąpienie zadania %@"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancela esta ocorrência de %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отменяет это повторение задачи «%@»"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ için yalnızca bu tekrarı iptal eder"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅取消“%@”的这一次"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅取消「%@」的這一次"
          }
        }
      }
    },
    "watch.action.cancel.message": {
      "comment": "Confirmation message for cancelling a task",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bei wiederkehrenden Aufgaben wird nur diese Wiederholung abgebrochen; zukünftige Wiederholungen bleiben bestehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For repeating tasks, only this occurrence is cancelled and future occurrences continue."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En las tareas recurrentes, solo se cancela esta repetición; las repeticiones futuras continúan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour les tâches récurrentes, seule cette occurrence est annulée ; les occurrences suivantes restent actives."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per le attività ricorrenti, viene annullata solo questa occorrenza; quelle future continuano."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "繰り返しタスクでは、今回分のみがキャンセルされ、次回以降は継続されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "반복 작업에서는 이번 회차만 취소되며 이후 회차는 계속됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W przypadku zadań cyklicznych anulowane zostanie tylko to wystąpienie, a przyszłe wystąpienia pozostaną bez zmian."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Em tarefas recorrentes, apenas esta ocorrência é cancelada, e as ocorrências futuras continuam."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для повторяющихся задач отменяется только это повторение, а будущие повторения сохраняются."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekrarlanan görevlerde yalnızca bu tekrar iptal edilir; sonraki tekrarlar devam eder."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对于重复任务，只会取消本次，之后的任务仍会继续。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "對於重複任務，只會取消本次，之後的任務仍會繼續。"
          }
        }
      }
    },
    "watch.action.cancel.none": {
      "comment": "Accessibility hint shown when there is no task to cancel",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Aufgabe zum Abbrechen"

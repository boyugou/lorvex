    "task_detail.reminders.empty.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge eine Erinnerung hinzu, um vor Fälligkeit dieser Aufgabe benachrichtigt zu werden."

          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同步模式"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "同步模式"
          }
        }
      }
    },
    "settings.sync.mode.detail.live": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bei jeder Aktualisierung von Lorvex lädt die Cloud-Synchronisierung lokale Änderungen in iCloud hoch und ruft Änderungen aus iCloud ab."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud Sync pushes local changes to iCloud and pulls remote changes when Lorvex refreshes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando Lorvex se actualiza, la sincronización en la nube sube los cambios locales a iCloud y descarga los cambios remotos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À chaque actualisation de Lorvex, la synchronisation cloud envoie les modifications locales vers iCloud et récupère les modifications distantes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando Lorvex si aggiorna, la sincronizzazione cloud carica le modifiche locali su iCloud e scarica quelle remote."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クラウド同期はローカルの変更を iCloud に送信し、Lorvex の更新時にリモートの変更を取得します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클라우드 동기화는 로컬 변경 사항을 iCloud로 보내고 Lorvex가 새로 고쳐질 때 원격 변경 사항을 가져옵니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchronizacja w chmurze wysyła lokalne zmiany do iCloud i pobiera zmiany zdalne podczas odświeżania Lorvex."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A sincronização na nuvem envia as alterações locais ao iCloud e busca as alterações remotas quando o Lorvex atualiza os dados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Облачная синхронизация отправляет локальные изменения в iCloud и получает удалённые изменения при обновлении данных в Lorvex."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bulut Eşitleme, yerel değişiklikleri iCloud’a gönderir ve Lorvex yenilendiğinde uzaktaki değişiklikleri alır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "云同步会将本地更改推送到 iCloud，并在 Lorvex 刷新时拉取远程更改。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "雲端同步會將本機變更推送至 iCloud，並在 Lorvex 重新整理時拉取遠端變更。"
          }
        }
      }
    },
    "settings.sync.mode.detail.off": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Cloud-Synchronisierung ist deaktiviert. Lokale Daten bleiben auf diesem Gerät."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud Sync is disabled. Local data stays on this device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La sincronización en la nube está desactivada. Los datos locales permanecen en este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La synchronisation cloud est désactivée. Les données locales restent sur cet appareil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La sincronizzazione cloud è disattivata. I dati locali restano su questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クラウド同期はオフです。ローカルデータはこのデバイスにのみ保存されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클라우드 동기화가 꺼져 있습니다. 로컬 데이터는 이 기기에만 저장됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchronizacja w chmurze jest wyłączona. Dane lokalne pozostają na tym urządzeniu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A sincronização na nuvem está desativada. Os dados locais permanecem neste dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Облачная синхронизация отключена. Локальные данные остаются на этом устройстве."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bulut Eşitleme devre dışı. Yerel veriler bu aygıtta kalır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "云同步已关闭。本地数据仅保留在此设备上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "雲端同步已關閉。本機資料僅保留在此裝置上。"
          }
        }
      }
    },

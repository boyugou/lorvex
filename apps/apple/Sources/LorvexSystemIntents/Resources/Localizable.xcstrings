        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットまたは Siri からキーを指定して Lorvex メモリエントリを読み取ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",

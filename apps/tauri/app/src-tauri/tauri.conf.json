{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lorvex",
  "version": "1.0.0",
  "identifier": "com.lorvex.planner",
  "build": {
    "beforeDevCommand": "cd .. && npm run -w app prepare:mcp -- --debug && npm run -w app dev",
    "beforeBuildCommand": "cd .. && npm run -w app prepare:mcp && npm run -w app build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Lorvex",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "transparent": false,
        "trafficLightPosition": { "x": 21, "y": 18 }
      },
      {
        "label": "popover",
        "title": "Lorvex Popover",
        "width": 380,
        "height": 420,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": [0, 0, 0, 0],
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "url": "index.html#popover"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src ipc: http://ipc.localhost; font-src 'self' data:; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'none'"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["lorvex"]
      },
      "mobile": [
        {
          "scheme": ["lorvex"]
        }
      ]
    },
    "updater": {
      "endpoints": [
        "https://github.com/boyugou/ai-native-todo/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxQUUzRTBCNENGNzBCMjYKUldRbUMvZE1DejZ1Z2FHeENxV2prU2pRY3ZYNkVZUlNXNnlRcWNMMEwzM2gveTdMM1JzRWdmRmsK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/mcp-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "resources/macos/Lorvex.entitlements",
      "infoPlist": "resources/macos/Info.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "14.0",
      "signingIdentity": null,
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.sectigo.com",
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libappindicator3-1"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "libappindicator-gtk3"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}

    "review.daily.read_only.footer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Frühere Tagesrückblicke sind mobil schreibgeschützt. Kehre zu heute zurück, um zu schreiben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Past daily reviews are read-only on mobile. Return to today to write."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las revisiones diarias pasadas son de solo lectura en móvil. Vuelve a hoy para escribir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les bilans quotidiens passés sont en lecture seule sur mobile. Revenez à aujourd’hui pour écrire."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le revisioni giornaliere passate sono di sola lettura su mobile. Torna a oggi per scrivere."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "過去のデイリーレビューはモバイルでは読み取り専用です。書くには今日に戻ってください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지난 일일 리뷰는 모바일에서 읽기 전용입니다. 작성하려면 오늘로 돌아가세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Poprzednie przeglądy dzienne są na urządzeniu mobilnym tylko do odczytu. Wróć do dziś, aby pisać."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisões diárias anteriores ficam somente leitura no celular. Volte para hoje para escrever."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прошлые ежедневные обзоры на мобильном доступны только для чтения. Вернитесь к сегодняшнему дню, чтобы писать."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Geçmiş günlük değerlendirmeler mobilde salt okunurdur. Yazmak için bugüne dönün."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "过去的每日回顾在移动端为只读。返回今天即可撰写。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "過去的每日回顧在行動裝置上為唯讀。返回今天即可撰寫。"
          }
        }
      }
    },

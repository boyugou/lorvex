          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어시스턴트 도우미를 실행할 수 없음"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie można uruchomić modułu pomocniczego asystenta"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O auxiliar do assistente não pode ser executado"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Помощник ассистента не запускается"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Asistan yardımcısı çalıştırılamıyor"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "助手帮助程序无法运行"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "助理輔助程式無法執行"
          }
        }
      }
    },
    "settings.mcp.helper_missing_detail": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex kann sein integriertes MCP-Hilfsprogramm nicht finden. Installiere Lorvex aus dem Originaldownload neu, um es wiederherzustellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex can’t find its built-in MCP helper. Reinstall Lorvex from the original download to restore it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex no encuentra su asistente MCP integrado. Reinstala Lorvex desde la descarga original para restaurarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex ne trouve pas son utilitaire MCP intégré. Réinstallez Lorvex à partir du téléchargement d’origine pour le restaurer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex non trova il suo helper MCP integrato. Reinstalla Lorvex dal download originale per ripristinarlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex の内蔵 MCP ヘルパーが見つかりません。元のダウンロードから Lorvex を再インストールして復元してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex가 내장 MCP 도우미를 찾을 수 없습니다. 원본 다운로드에서 Lorvex를 다시 설치하여 복원하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex nie może znaleźć wbudowanego modułu pomocniczego MCP. Zainstaluj ponownie Lorvex z oryginalnego pliku, aby go przywrócić."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lorvex não encontra o auxiliar MCP integrado. Reinstale o Lorvex a partir do download original para restaurá-lo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex не может найти встроенный помощник MCP. Переустановите Lorvex из исходной загрузки, чтобы восстановить его."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex, yerleşik MCP yardımcısını bulamıyor. Geri yüklemek için Lorvex’i orijinal indirmeden yeniden yükleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 找不到其内置的 MCP 帮助程序。请从原始下载重新安装 Lorvex 以恢复它。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 找不到其內建的 MCP 輔助程式。請從原始下載重新安裝 Lorvex 以還原它。"
          }
        }
      }
    },

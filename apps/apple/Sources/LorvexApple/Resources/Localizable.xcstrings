            "state": "translated",
            "value": "Mantenemos la cola de revisión lista mientras Lorvex actualiza los datos de las tareas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La file de révision reste prête pendant que Lorvex actualise les données des tâches."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Manteniamo pronta la coda di revisione mentre Lorvex aggiorna i dati delle attività."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex がタスクデータを更新する間、レビューキューを準備状態に保ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex가 작업 데이터를 새로 고치는 동안 검토 대기열을 준비 상태로 유지합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Utrzymujemy gotowość kolejki przeglądu, gdy Lorvex odświeża dane zadań."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantemos a fila de revisão pronta enquanto o Lorvex atualiza os dados das tarefas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очередь обзора остаётся готовой, пока Lorvex обновляет данные задач."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex görev verilerini yenilerken inceleme kuyruğu hazır tutulur."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Lorvex 刷新任务数据时，保持复查队列就绪。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Lorvex 重新整理任務資料時，保持複查佇列就緒。"
          }
        }
      }
    },

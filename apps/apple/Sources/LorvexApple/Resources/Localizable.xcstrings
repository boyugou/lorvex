    "tips.mcp_assistant.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex ist darauf ausgelegt, dass KI-Assistenten den Großteil der Arbeit übernehmen. Verbinde deinen MCP-fähigen Client, um loszulegen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex is built for AI assistants to do most of the work. Connect your MCP-capable client to get started."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex está diseñado para que los asistentes de IA hagan la mayor parte del trabajo. Conecta tu cliente compatible con MCP para empezar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex est conçu pour que les assistants IA effectuent l'essentiel du travail. Connectez votre client compatible MCP pour commencer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex è pensato perché gli assistenti IA svolgano la maggior parte del lavoro. Collega il tuo client compatibile con MCP per iniziare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex は AI アシスタントが作業の大半を行うように作られています。MCP 対応クライアントを接続して始めましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex는 AI 어시스턴트가 대부분의 작업을 하도록 만들어졌습니다. MCP 지원 클라이언트를 연결해 시작하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex jest stworzony tak, by asystenci AI wykonywali większość pracy. Połącz klienta obsługującego MCP, aby zacząć."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lorvex foi feito para que assistentes de IA façam a maior parte do trabalho. Conecte seu cliente compatível com MCP para começar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex создан так, чтобы большую часть работы выполняли ИИ-ассистенты. Подключите клиент с поддержкой MCP, чтобы начать."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex, işin çoğunu yapay zeka asistanlarının yapması için tasarlandı. Başlamak için MCP uyumlu istemcinizi bağlayın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 专为 AI 助手完成大部分工作而设计。连接支持 MCP 的客户端即可开始。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 專為 AI 助手完成大部分工作而設計。連接支援 MCP 的用戶端即可開始。"
          }
        }
      }
    },

    "settings.permissions.show_task_notes_footer": {
      "comment": "Footer explaining the show-task-notes-in-notifications toggle's default-off behavior",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ist die Option deaktiviert, zeigen Erinnerungen auf dem Sperrbildschirm und in Bannern nur den Aufgabentitel – nie Ihre Notizen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When off, reminders show only the task title — never your notes — on the lock screen and banners."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si está desactivado, los recordatorios muestran solo el título de la tarea (nunca tus notas) en la pantalla de bloqueo y en los avisos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque l'option est désactivée, les rappels n'affichent que le titre de la tâche — jamais vos notes — sur l'écran verrouillé et dans les bannières."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se disattivata, i promemoria mostrano solo il titolo dell'attività — mai le tue note — nella schermata di blocco e nei banner."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフの場合、リマインダーはロック画面やバナーにタスクのタイトルのみを表示し、メモは表示しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "꺼져 있으면 알림은 잠금 화면과 배너에 작업 제목만 표시하며 메모는 표시하지 않습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gdy wyłączone, przypomnienia pokazują na ekranie blokady i w banerach tylko tytuł zadania — nigdy Twoich notatek."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando desativado, os lembretes mostram apenas o título da tarefa — nunca as suas notas — na tela de bloqueio e nos banners."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если параметр отключён, напоминания показывают на экране блокировки и в баннерах только название задачи, но не ваши заметки."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kapalıyken hatırlatıcılar kilit ekranında ve bannerlarda yalnızca görev başlığını gösterir — notlarınızı asla göstermez."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭时，提醒仅在锁屏和横幅通知中显示任务标题，绝不显示你的备注。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關閉時，提醒僅在鎖定畫面和橫幅通知中顯示任務標題，絕不顯示你的備註。"
          }
        }
      }
    },

    "system.task.reminders.due.read.description": {
      "comment": "Description for the Read Lorvex Due Task Reminders App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausstehende Lorvex-Aufgabenerinnerungen lesen, die fällig sind."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read pending Lorvex task reminders that are due."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee los recordatorios de tareas pendientes de Lorvex que están vencidos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lire les rappels de tâches Lorvex en attente arrivés à échéance."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Leggi i promemoria delle attività Lorvex in sospeso che sono in scadenza."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "期限が到来している保留中の Lorvex タスクリマインダーを読み取ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기한이 도래한 대기 중인 Lorvex 작업 알림을 읽습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odczytaj oczekujące przypomnienia o zadaniach Lorvex, których termin nadszedł."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Lê os lembretes de tarefas pendentes do Lorvex que estão vencidos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чтение ожидающих напоминаний о задачах Lorvex, срок которых наступил."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zamanı gelen bekleyen Lorvex görev hatırlatıcılarını oku."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "读取已经到期的待处理 Lorvex 任务提醒。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讀取已經到期的待處理 Lorvex 任務提醒。"
          }
        }
      }
    },

    "memory.detail.empty.description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle einen Speichereintrag, um seinen Inhalt und seinen Änderungsverlauf zu prüfen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose a memory entry to inspect its content."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige una entrada de memoria para inspeccionar su contenido y su historial de revisiones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une entrée de mémoire pour en examiner le contenu et l'historique des révisions."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli una voce di memoria per esaminarne il contenuto e la cronologia delle revisioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メモリのエントリを選んで、内容と改訂履歴を確認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메모리 항목을 선택해 내용과 수정 기록을 확인하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz wpis pamięci, aby przejrzeć jego zawartość i historię wersji."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha uma entrada de memória para inspecionar o seu conteúdo e o histórico de revisões."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите запись памяти, чтобы просмотреть её содержимое и историю изменений."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İçeriğini ve düzeltme geçmişini incelemek için bir bellek girişi seçin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择一个记忆条目，以查看内容和修订历史。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇一個記憶條目，以檢視內容與修訂歷史。"
          }
        }
      }
    },

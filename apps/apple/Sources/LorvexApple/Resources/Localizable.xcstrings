    "setup.permissions.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex kann Kalender und Mitteilungen integrieren. Beide Integrationen sind optional."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex can integrate with Calendar and Notifications. Each is optional."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex puede integrarse con Calendario y Notificaciones. Ambas integraciones son opcionales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex peut s’intégrer à Calendrier et à Notifications. Chaque intégration est facultative."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex può integrarsi con Calendario e Notifiche. Entrambe le integrazioni sono facoltative."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex はカレンダーや通知と連携できます。どちらも任意です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex는 캘린더 및 알림과 연동할 수 있습니다. 두 기능 모두 선택 사항입니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex może integrować się z Kalendarzem i Powiadomieniami. Obie integracje są opcjonalne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lorvex pode integrar-se ao Calendário e às Notificações. Ambas as integrações são opcionais."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex может интегрироваться с Календарём и Уведомлениями. Обе интеграции необязательны."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex, Takvim ve Bildirimler ile entegre olabilir. Her iki entegrasyon da isteğe bağlıdır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 可以与日历和通知集成。两项集成都可选。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 可以與行事曆和通知整合。兩項整合皆為選用。"
          }
        }
      }
    },

    "settings.sync.resume.confirm.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex lädt die auf diesem Gerät gespeicherten Daten in den aktuell angemeldeten iCloud-Account hoch und setzt die Synchronisierung fort."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex will upload the data stored on this device to the currently signed-in iCloud account and resume syncing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex subirá los datos guardados en este dispositivo a la cuenta de iCloud con la sesión iniciada actualmente y reanudará la sincronización."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex téléversera les données stockées sur cet appareil vers le compte iCloud actuellement connecté et reprendra la synchronisation."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex caricherà i dati archiviati su questo dispositivo nell’account iCloud attualmente connesso e riprenderà la sincronizzazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex はこのデバイスに保存されているデータを、現在サインイン中の iCloud アカウントにアップロードして同期を再開します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex가 이 기기에 저장된 데이터를 현재 로그인된 iCloud 계정으로 업로드하고 동기화를 재개합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex prześle dane zapisane na tym urządzeniu do aktualnie zalogowanego konta iCloud i wznowi synchronizację."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lorvex enviará os dados armazenados neste dispositivo para a conta do iCloud com sessão iniciada no momento e retomará a sincronização."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex загрузит данные, хранящиеся на этом устройстве, в текущую учётную запись iCloud и возобновит синхронизацию."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex, bu aygıtta saklanan verileri şu anda oturum açılmış iCloud hesabına yükleyip eşitlemeyi sürdürecek."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 会将此设备上存储的数据上传到当前登录的 iCloud 账户，并恢复同步。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 會將此裝置上儲存的資料上傳到目前登入的 iCloud 帳號，並恢復同步。"
          }
        }
      }
    },
    "settings.sync.resume.confirm.title": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Daten dieses Geräts erneut hochladen und Synchronisierung fortsetzen?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Re-upload this device’s data and resume sync?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Volver a subir los datos de este dispositivo y reanudar la sincronización?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Téléverser à nouveau les données de cet appareil et reprendre la synchronisation ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricaricare i dati di questo dispositivo e riprendere la sincronizzazione?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスのデータを再アップロードして同期を再開しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기의 데이터를 다시 업로드하고 동기화를 재개하시겠습니까?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przesłać ponownie dane z tego urządzenia i wznowić synchronizację?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Reenviar os dados deste dispositivo e retomar a sincronização?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Загрузить данные этого устройства заново и возобновить синхронизацию?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu aygıtın verileri yeniden yüklensin ve eşitleme sürdürülsün mü?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要重新上传此设备的数据并恢复同步吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "要重新上傳此裝置的資料並恢復同步嗎？"
          }
        }
      }
    },
    "settings.working_hours.caption": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeitplan-Vorschläge legen Fokusblöcke in dieses Fenster."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Schedule proposals fit focus blocks inside this window."
          }
        },
        "es": {

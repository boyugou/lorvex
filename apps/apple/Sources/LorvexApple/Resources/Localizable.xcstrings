    "settings.cloud_sync.paused.account_changed": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der angemeldete iCloud-Account hat sich geändert. Die Synchronisierung ist pausiert, damit die Daten dieses Mac nicht in einen anderen Account gelangen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The signed-in iCloud account changed. Sync is paused so this Mac’s data isn’t mixed into a different account."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cuenta de iCloud con la sesión iniciada ha cambiado. La sincronización está en pausa para que los datos de este Mac no se mezclen con otra cuenta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le compte iCloud connecté a changé. La synchronisation est en pause afin que les données de ce Mac ne soient pas mélangées à un autre compte."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L’account iCloud con cui è stato eseguito l’accesso è cambiato. La sincronizzazione è in pausa così i dati di questo Mac non finiscono in un altro account."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインイン中の iCloud アカウントが変わりました。この Mac のデータが別のアカウントに混ざらないよう、同期は一時停止されています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인된 iCloud 계정이 변경되었습니다. 이 Mac의 데이터가 다른 계정에 섞이지 않도록 동기화가 일시 정지되었습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zalogowane konto iCloud uległo zmianie. Synchronizacja jest wstrzymana, aby dane z tego Maca nie trafiły do innego konta."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A conta do iCloud com sessão iniciada mudou. A sincronização está pausada para que os dados deste Mac não se misturem com outra conta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вошедшая учётная запись iCloud изменилась. Синхронизация приостановлена, чтобы данные этого Mac не смешались с другой учётной записью."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Oturum açılan iCloud hesabı değişti. Bu Mac’in verileri farklı bir hesaba karışmasın diye eşitleme duraklatıldı."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录的 iCloud 账户已更改。同步已暂停，以防这台 Mac 的数据混入其他账户。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "登入的 iCloud 帳號已變更。同步已暫停，以免這台 Mac 的資料混入其他帳號。"
          }
        }
      }
    },
    "settings.cloud_sync.paused.backfill_failed": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Vorbereitung des erneuten Hochladens ist fehlgeschlagen. Beim Fortsetzen wird es erneut versucht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Preparing the re-upload failed. Resuming will retry it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo preparar la resubida. Al reanudar se volverá a intentar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La préparation du nouveau téléversement a échoué. La reprise réessaiera."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La preparazione del nuovo caricamento non è riuscita. Alla ripresa verrà ritentata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "再アップロードの準備に失敗しました。再開すると再試行されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다시 업로드 준비에 실패했습니다. 재개하면 다시 시도합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przygotowanie ponownego przesyłania nie powiodło się. Wznowienie spowoduje ponowną próbę."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao preparar o reenvio. Retomar tentará novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось подготовить повторную загрузку. При возобновлении попытка повторится."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeniden yükleme hazırlığı başarısız oldu. Sürdürüldüğünde yeniden denenecek."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "准备重新上传失败。恢复同步时将重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "準備重新上傳失敗。恢復同步時將重試。"
          }
        }
      }
    },
    "settings.cloud_sync.paused.user_deleted_zone": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Lorvex-Daten wurden aus iCloud gelöscht. Die Synchronisierung bleibt pausiert, damit dieser Mac sie nicht ohne Ihre Zustimmung erneut hochlädt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex data was deleted from iCloud. Sync stays paused so this Mac doesn’t re-upload it without your consent."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los datos de Lorvex se eliminaron de iCloud. La sincronización sigue en pausa para que este Mac no vuelva a subirlos sin tu consentimiento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les données Lorvex ont été supprimées d’iCloud. La synchronisation reste en pause afin que ce Mac ne les téléverse pas à nouveau sans votre accord."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I dati di Lorvex sono stati eliminati da iCloud. La sincronizzazione resta in pausa così questo Mac non li ricarica senza il tuo consenso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex データが iCloud から削除されました。この Mac が同意なくデータを再アップロードしないよう、同期は一時停止のままになります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 데이터가 iCloud에서 삭제되었습니다. 이 Mac이 동의 없이 데이터를 다시 업로드하지 않도록 동기화가 일시 정지된 상태로 유지됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dane Lorvex zostały usunięte z iCloud. Synchronizacja pozostaje wstrzymana, aby ten Mac nie przesłał ich ponownie bez Twojej zgody."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os dados do Lorvex foram excluídos do iCloud. A sincronização permanece pausada para que este Mac não os envie novamente sem o seu consentimento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Данные Lorvex были удалены из iCloud. Синхронизация остаётся приостановленной, чтобы этот Mac не загрузил их заново без вашего согласия."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex verileri iCloud’dan silindi. Bu Mac verileri onayınız olmadan yeniden yüklemesin diye eşitleme duraklatılmış kalır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 数据已从 iCloud 中删除。同步保持暂停，以防这台 Mac 在未经你同意的情况下重新上传数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 資料已從 iCloud 中刪除。同步保持暫停，以免這台 Mac 在未經你同意的情況下重新上傳資料。"
          }
        }
      }
    },
    "settings.cloud_sync.paused.user_deleted_zone.retry_hint": {
      "comment": "Second sentence of the userDeletedZone pause notice: how to recover if the deletion was interrupted mid-way (running it again is safe and idempotent)",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wurde das Löschen unterbrochen, bevor es abgeschlossen war, führen Sie „iCloud-Daten löschen“ erneut aus, um es sicher abzuschließen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If the deletion was interrupted before it finished, run Delete iCloud Data again to complete it safely."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si la eliminación se interrumpió antes de terminar, ejecuta Eliminar datos de iCloud de nuevo para completarla de forma segura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si la suppression a été interrompue avant la fin, relancez Supprimer les données iCloud pour la terminer en toute sécurité."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se l'eliminazione è stata interrotta prima di terminare, esegui di nuovo Elimina dati iCloud per completarla in modo sicuro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除が完了する前に中断された場合は、「iCloud データを削除」をもう一度実行すると安全に完了できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "삭제가 완료되기 전에 중단된 경우 iCloud 데이터 삭제를 다시 실행하면 안전하게 완료됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli usuwanie zostało przerwane przed zakończeniem, uruchom ponownie Usuń dane iCloud, aby bezpiecznie je dokończyć."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Se a exclusão foi interrompida antes de terminar, execute Excluir Dados do iCloud novamente para concluí-la com segurança."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если удаление было прервано до завершения, снова выполните «Удалить данные iCloud», чтобы безопасно его завершить."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Silme işlemi tamamlanmadan kesildiyse, güvenle tamamlamak için iCloud Verilerini Sil'i yeniden çalıştırın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果删除在完成前被中断，再次运行“删除 iCloud 数据”即可安全地完成。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果刪除在完成前被中斷，再次執行「刪除 iCloud 資料」即可安全地完成。"
          }
        }
      }
    },

    "system.task.provider_event.unlink.description": {
      "comment": "Description for the Unlink Lorvex Task From Provider Event App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entferne die Verknüpfung einer Aufgabe mit einem Kalenderereignis des Anbieters."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove the link between a Lorvex task and an external calendar event."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Quita el vínculo entre una tarea y un evento de calendario del proveedor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Retirez le lien entre une tâche et un événement de calendrier du fournisseur."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuovi un collegamento tra un'attività e un evento di calendario del provider."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タスクとプロバイダーのカレンダーイベントとのリンクを削除します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작업과 공급자 캘린더 이벤트 간의 연결을 제거합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usuń połączenie zadania z wydarzeniem w kalendarzu dostawcy."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Remova o vínculo entre uma tarefa e um evento de calendário do provedor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удаляет связь задачи с событием календаря провайдера."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir görev-sağlayıcı takvim etkinliği bağlantısını kaldır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "移除任务与提供方日历事件的关联。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "移除任務與供應方行事曆事件的連結。"
          }
        }
      }
    },
    "system.task.provider_event.unlink.dialog": {

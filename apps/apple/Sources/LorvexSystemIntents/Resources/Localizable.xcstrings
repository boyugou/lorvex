    "system.focus_filter.description": {
      "comment": "Description for the Lorvex Focus system Focus Filter",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einen System-Fokusmodus an ein Lorvex-Fokusprofil binden und Aufgaben außerhalb des Fokus in Widgets ausblenden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scope a system Focus mode to a Lorvex focus profile, hiding non-focus tasks from widgets."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vincula un modo de Concentración del sistema a un perfil de enfoque de Lorvex, ocultando las tareas no relacionadas con el enfoque en widgets."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Associez un mode Concentration du système à un profil de concentration Lorvex, en masquant les tâches hors concentration des widgets."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Limita una modalità Full immersion di sistema a un profilo di focus Lorvex, nascondendo le attività non di focus da widget."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムの集中モードを Lorvex の集中プロファイルに紐付け、集中対象外のタスクをウィジェットから非表示にします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 집중 모드를 Lorvex 집중 프로파일에 연결하여 집중과 무관한 작업을 위젯에서 숨깁니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogranicz systemowy tryb skupienia do profilu skupienia Lorvex, ukrywając zadania spoza skupienia w widżetach."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Associe um modo Foco do sistema a um perfil de foco do Lorvex, ocultando tarefas não relacionadas ao foco em widgets."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Привяжите системный режим фокусирования к профилю фокусировки Lorvex, скрывая нефокусные задачи из виджетов."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir sistem Odak modunu bir Lorvex odak profiline kapsamlayın; böylece odak dışı görevler widget'lardan gizlenir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将系统专注模式关联到 Lorvex 专注配置，并在小组件中隐藏非专注任务。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將系統「專注」模式關聯到 Lorvex 專注設定檔，並在小工具中隱藏非專注任務。"
          }
        }
      }
    },

    "settings.cloud_sync.resume.action": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erneut hochladen & Synchronisierung fortsetzen…"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Re-upload & Resume Sync…"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Volver a subir y reanudar sincronización…"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Téléverser à nouveau et reprendre la synchronisation…"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricarica e riprendi la sincronizzazione…"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "再アップロードして同期を再開…"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다시 업로드하고 동기화 재개…"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Prześlij ponownie i wznów synchronizację…"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Reenviar e retomar sincronização…"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Загрузить заново и возобновить синхронизацию…"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeniden Yükle ve Eşitlemeyi Sürdür…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重新上传并恢复同步…"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "重新上傳並恢復同步…"
          }
        }
      }

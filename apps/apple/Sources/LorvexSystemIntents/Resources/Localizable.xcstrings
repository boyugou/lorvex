          "stringUnit": {
            "state": "translated",
            "value": "¿Restablecer este hábito? Se borrarán las finalizaciones registradas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réinitialiser cette habitude ? Les accomplissements enregistrés seront effacés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Reimpostare questa abitudine? I completamenti registrati verranno cancellati."

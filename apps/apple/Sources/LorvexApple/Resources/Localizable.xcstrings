    "memory.empty.description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Notizen, die Sie oder Ihr Assistent zu Ihren Vorlieben und Ihrem Kontext speichern, erscheinen hier."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Notes you or your assistant save about your preferences and context appear here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las notas que tú o tu asistente guardéis sobre tus preferencias y contexto aparecen aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les notes que vous ou votre assistant enregistrez sur vos préférences et votre contexte apparaissent ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le note che tu o il tuo assistente salvate sulle tue preferenze e sul contesto appaiono qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたやアシスタントが好みやコンテキストについて保存したメモがここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용자나 어시스턴트가 선호도와 맥락에 대해 저장한 메모가 여기에 표시됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutaj pojawiają się notatki o Twoich preferencjach i kontekście zapisane przez Ciebie lub asystenta."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As notas que você ou seu assistente salvam sobre suas preferências e contexto aparecem aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Здесь появляются заметки о ваших предпочтениях и контексте, сохранённые вами или ассистентом."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sizin veya asistanınızın tercihleriniz ve bağlamınız hakkında kaydettiği notlar burada görünür."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你或助手保存的关于你的偏好和背景的笔记会显示在这里。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你或助手儲存的關於你的偏好與情境的筆記會顯示在這裡。"
          }
        }
      }
    },

    "habits.reminders.hint.daily": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur an den geplanten Tagen dieser Gewohnheit – und endet, sobald sie erledigt ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only on the days this habit is scheduled, and stops once it's done."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo los días en que este hábito está programado, y se detiene al completarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uniquement les jours où cette habitude est prévue, et s'arrête une fois faite."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo nei giorni in cui questa abitudine è pianificata, e si ferma una volta completata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この習慣が予定されている日のみ。完了すると停止します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 습관이 예정된 날에만, 완료하면 중지됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tylko w dni zaplanowane dla tego nawyku i kończy się po wykonaniu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas nos dias em que este hábito está agendado, e para quando concluído."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Только в запланированные для этой привычки дни; прекращается после выполнения."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca bu alışkanlığın planlandığı günlerde; tamamlanınca durur."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅在该习惯计划的日子提醒，完成后即停止。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅在該習慣排定的日子提醒，完成後即停止。"
          }
        }
      }
    },
    "habits.reminders.hint.monthly": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erinnert am %lld. Tag jeden Monat und endet, sobald es erledigt ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reminds on day %lld each month, and stops once it's done."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Avisa el día %lld de cada mes y se detiene cuando está hecho."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rappel le %lld de chaque mois, et s'arrête une fois fait."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Promemoria il giorno %lld di ogni mese, e si ferma quando è fatto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",

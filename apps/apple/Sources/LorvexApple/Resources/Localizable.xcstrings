    "settings.mcp.helper_runtime_failed_detail": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex hat den Helfer gefunden, aber er konnte mit den aktuellen Speichereinstellungen nicht gestartet werden. Verbinde Lorvex unter Einstellungen > Assistent neu oder installiere die App neu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex found the helper, but it could not start with the current storage settings. Reconnect Lorvex in Settings > Assistant or reinstall the app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex encontró el asistente, pero no pudo iniciarse con la configuración de almacenamiento actual. Vuelve a conectar Lorvex en Ajustes > Asistente o reinstala la app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex a trouvé l’assistant, mais il n’a pas pu démarrer avec les réglages de stockage actuels. Reconnectez Lorvex dans Réglages > Assistant ou réinstallez l’app."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex ha trovato l’helper, ma non è riuscito ad avviarsi con le impostazioni di archiviazione attuali. Riconnetti Lorvex in Impostazioni > Assistente o reinstalla l’app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex はヘルパーを検出しましたが、現在のストレージ設定では起動できませんでした。「設定」>「アシスタント」で Lorvex を再接続するか、アプリを再インストールしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex가 도우미를 찾았지만 현재 저장 공간 설정으로는 시작할 수 없습니다. 설정 > 어시스턴트에서 Lorvex를 다시 연결하거나 앱을 다시 설치하세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex znalazł pomocnika, ale nie udało się go uruchomić z bieżącymi ustawieniami pamięci. Połącz Lorvex ponownie w Ustawienia > Asystent lub zainstaluj aplikację ponownie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lorvex encontrou o auxiliar, mas não foi possível iniciá-lo com as configurações de armazenamento atuais. Reconecte o Lorvex em Ajustes > Assistente ou reinstale o app."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex нашёл помощник, но его не удалось запустить с текущими настройками хранилища. Переподключите Lorvex в разделе «Настройки» > «Ассистент» или переустановите приложение."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex yardımcıyı buldu ancak geçerli depolama ayarlarıyla başlatılamadı. Lorvex'i Ayarlar > Asistan bölümünden yeniden bağlayın veya uygulamayı yeniden yükleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 找到了助手，但无法在当前存储设置下启动。请在“设置 > 助手”中重新连接 Lorvex，或重新安装应用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 找到了輔助程式，但無法在目前的儲存設定下啟動。請在「設定 > 助理」中重新連接 Lorvex，或重新安裝 App。"
          }
        }
      }
    },

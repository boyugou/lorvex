          "stringUnit": {
            "state": "translated",
            "value": "Eine Aufgabe pro Zeile erfassen — dein Assistent sortiert Prioritäten, Daten und Listen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture one task per line — your assistant sorts the priorities, dates, and lists."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Captura una tarea por línea — tu asistente ordena las prioridades, fechas y listas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Capturez une tâche par ligne — votre assistant trie les priorités, dates et listes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Acquisisci un'attività per riga — il tuo assistente ordina le priorità, le date e gli elenchi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1行に1タスクを入力してください — アシスタントが優先度、日付、リストを整理します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "한 줄에 작업 하나씩 입력하세요 — 어시스턴트가 우선순위, 날짜, 목록을 정리합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wpisz jedno zadanie na wiersz — twój asystent posortuje priorytety, daty i listy."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture uma tarefa por linha — seu assistente organiza as prioridades, datas e listas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Записывайте по одной задаче в строку — ваш помощник расставит приоритеты, даты и списки."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Satır başına bir görev yazın — asistanınız öncelikleri, tarihleri ve listeleri sıralar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每行记录一项任务 — 助手会自动整理优先级、日期和列表。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每行記錄一項任務 — 助手會自動整理優先順序、日期和清單。"
          }
        }
      }
    },

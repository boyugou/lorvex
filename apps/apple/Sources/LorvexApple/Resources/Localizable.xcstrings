    "settings.data_export.description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sichere die ausgewählten Kategorien als JSON-Datei, als tabellenkalkulationsfreundliche CSV oder als ZIP (eine JSON pro Kategorie). Für Backups oder zum Öffnen deiner Daten in anderen Tools – nicht zum Wechseln zwischen Lorvex-Installationen (verwende dafür Migration)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save the categories you pick as a JSON file, a spreadsheet-friendly CSV, or a ZIP (one JSON per category). For backups, moving your data to another Lorvex install, or opening it in other tools."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda las categorías que elijas como archivo JSON, como CSV compatible con hojas de cálculo o como ZIP (un JSON por categoría). Para copias de seguridad o para abrir tus datos en otras herramientas, no para moverlos entre instalaciones de Lorvex (usa Migración para eso)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrez les catégories sélectionnées dans un fichier JSON, un CSV compatible avec les tableurs ou un ZIP (un JSON par catégorie). Pour des sauvegardes ou pour ouvrir vos données dans d'autres outils — pas pour les transférer entre installations Lorvex (utilisez Migration pour cela)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salva le categorie che selezioni come file JSON, come CSV compatibile con i fogli di calcolo o come ZIP (un JSON per categoria). Per backup o per aprire i tuoi dati in altri strumenti, non per spostarli tra installazioni di Lorvex (per questo usa Migrazione)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したカテゴリを JSON ファイル、表計算ソフトで扱える CSV、または ZIP（カテゴリごとに 1 つの JSON）として保存します。バックアップや他のツールでデータを開くためのもので、Lorvex のインストール間でデータを移すためのものではありません（それには移行を使ってください）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 카테고리를 JSON 파일, 스프레드시트에서 쓰기 좋은 CSV 또는 ZIP(카테고리당 JSON 하나)으로 저장합니다. 백업하거나 다른 도구에서 데이터를 열기 위한 것이며, Lorvex 설치본 간 이동용이 아닙니다(이때는 마이그레이션을 사용하세요)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapisz wybrane kategorie jako plik JSON, plik CSV przyjazny dla arkuszy kalkulacyjnych lub jako ZIP (jeden plik JSON na kategorię). Do kopii zapasowych lub otwierania danych w innych narzędziach — nie do przenoszenia między instalacjami Lorvex (do tego użyj Migracji)."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Salve as categorias que escolher como arquivo JSON, como CSV compatível com planilhas ou como ZIP (um JSON por categoria). Para backups ou para abrir seus dados em outras ferramentas — não para mover entre instalações do Lorvex (use Migração para isso)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сохраните выбранные категории в виде файла JSON, CSV для электронных таблиц или ZIP (по одному JSON на категорию). Для резервных копий или открытия данных в других инструментах — не для переноса между установками Lorvex (для этого используйте «Перенос»)."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seçtiğiniz kategorileri JSON dosyası, elektronik tablolarla uyumlu bir CSV ya da bir ZIP (kategori başına bir JSON) olarak kaydedin. Yedekler için veya verilerinizi başka araçlarda açmak içindir — Lorvex kurulumları arasında taşımak için değil (bunun için Taşıma'yı kullanın)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将所选类别保存为 JSON 文件、便于电子表格使用的 CSV，或 ZIP（每个类别一个 JSON）。用于备份或在其他工具中打开数据，而非在 Lorvex 安装之间迁移（迁移请使用“迁移”）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將所選類別儲存為 JSON 檔案、方便試算表使用的 CSV，或 ZIP（每個類別一個 JSON）。用於備份或在其他工具中開啟資料，而非在 Lorvex 安裝之間搬移（搬移請使用「遷移」）。"
          }
        }
      }
    },

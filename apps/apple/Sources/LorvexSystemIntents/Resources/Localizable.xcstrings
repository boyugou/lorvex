    "system.task.reminders.set.description": {
      "comment": "Description for the Set Lorvex Task Reminders App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ersetze die Erinnerungszeitstempel einer Lorvex-Aufgabe aus Kurzbefehlen oder Siri."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Replace a Lorvex task's reminder timestamps from Shortcuts or Siri."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reemplaza las marcas de tiempo de recordatorio de una tarea de Lorvex desde Atajos o Siri."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Remplacez les horodatages de rappel d'une tâche Lorvex depuis Raccourcis ou Siri."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sostituisci i timestamp dei promemoria di un'attività Lorvex da Comandi rapidi o Siri."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットまたはSiriからLorvexタスクのリマインダーのタイムスタンプを置き換えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축어 또는 Siri에서 Lorvex 작업의 미리 알림 타임스탬프를 교체합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zastąp znaczniki czasu przypomnień zadania Lorvex ze Skrótów lub Siri."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Substitua os carimbos de data/hora de lembrete de uma tarefa do Lorvex a partir de Atalhos ou Siri."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Замена меток времени напоминаний задачи Lorvex из «Команд» или Siri."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısayollar veya Siri ile bir Lorvex görevinin hatırlatıcı zaman damgalarını değiştir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从“快捷指令”或 Siri 替换一个 Lorvex 任务的提醒时间戳。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從「捷徑」或 Siri 替換一個 Lorvex 任務的提醒時間戳記。"
          }
        }
      }
    },

          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les tâches sélectionnées seront annulées. Vous pouvez les rouvrir individuellement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le attività selezionate verranno annullate. Puoi riaprirle singolarmente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したタスクがキャンセルされます。個別に再開できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 작업이 취소됩니다. 개별적으로 다시 열 수 있습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybrane zadania zostaną anulowane. Możesz otworzyć je ponownie pojedynczo."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As tarefas selecionadas serão canceladas. Você pode reabri-las individualmente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбранные задачи будут отменены. Вы можете открыть их снова по отдельности."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seçili görevler iptal edilecek. Bunları tek tek yeniden açabilirsiniz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所选任务将被取消。你可以单独重新打开它们。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "所選任務將被取消。你可以單獨重新開啟它們。"
          }
        }
      }
    },

    "setup.welcome.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex ist ein KI-first-Planer – deine Assistenz übernimmt den Großteil der Eingaben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex is an AI-first planner — your assistant does most of the writing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex es un planificador centrado en la IA: tu asistente hace la mayor parte de la escritura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex est un planificateur axé sur l'IA — votre assistant rédige l'essentiel."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex è un planner AI-first: il tuo assistente scrive la maggior parte delle cose."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex は AI ファーストのプランナーです。入力の大半はアシスタントが行います。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex는 AI 우선 플래너입니다. 대부분의 입력은 어시스턴트가 처리합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex to planer stawiający na AI — większość wpisów tworzy asystent."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lorvex é um planejador focado em IA — seu assistente faz a maior parte da escrita."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex — планировщик с приоритетом ИИ: большую часть записей делает ассистент."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex, yapay zeka öncelikli bir planlayıcıdır — yazıların çoğunu asistanınız yapar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 是 AI 优先的规划工具——大部分录入由助手完成。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 是 AI 優先的規劃工具——大部分輸入由助手完成。"
          }
        }
      }
    },

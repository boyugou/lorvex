    "settings.cloud_delete.detail": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löscht alle Lorvex-Einträge aus Ihrem iCloud-Account – für alle Geräte, die damit synchronisieren. Die lokalen Daten auf diesem Mac bleiben unberührt. Die iCloud-Synchronisierung wird ausgeschaltet und bleibt aus, bis Sie sie wieder aktivieren; dabei werden die Daten dieses Mac erneut hochgeladen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete every Lorvex record from your iCloud account — for all devices that sync with it. The local data on this Mac is not touched. iCloud sync turns off and stays off until you re-enable it, which re-uploads this Mac’s data."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina todos los registros de Lorvex de tu cuenta de iCloud, para todos los dispositivos que sincronizan con ella. Los datos locales de este Mac no se tocan. La sincronización con iCloud se desactiva y permanece desactivada hasta que la reactives, lo que volverá a subir los datos de este Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprime tous les enregistrements Lorvex de votre compte iCloud — pour tous les appareils qui s’y synchronisent. Les données locales de ce Mac ne sont pas touchées. La synchronisation iCloud est désactivée et le reste jusqu’à ce que vous la réactiviez, ce qui téléversera à nouveau les données de ce Mac."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina tutti i record di Lorvex dal tuo account iCloud, per tutti i dispositivi che vi si sincronizzano. I dati locali su questo Mac non vengono toccati. La sincronizzazione iCloud viene disattivata e resta disattivata finché non la riattivi, operazione che ricaricherà i dati di questo Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud アカウントからすべての Lorvex レコードを削除します。これは同期しているすべてのデバイスに影響します。この Mac 上のローカルデータには影響しません。iCloud 同期はオフになり、再度有効にするまでオフのままです。再度有効にすると、この Mac のデータが再アップロードされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 계정에서 모든 Lorvex 레코드를 삭제합니다. 해당 계정과 동기화하는 모든 기기에 적용됩니다. 이 Mac의 로컬 데이터는 그대로 유지됩니다. iCloud 동기화는 꺼지며 다시 켤 때까지 꺼진 상태로 유지됩니다. 다시 켜면 이 Mac의 데이터가 다시 업로드됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usuwa wszystkie rekordy Lorvex z Twojego konta iCloud — dla wszystkich urządzeń, które się z nim synchronizują. Dane lokalne na tym Macu pozostają nietknięte. Synchronizacja iCloud zostaje wyłączona i pozostaje wyłączona, dopóki jej ponownie nie włączysz, co spowoduje ponowne przesłanie danych z tego Maca."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Exclui todos os registros do Lorvex da sua conta do iCloud — para todos os dispositivos que sincronizam com ela. Os dados locais neste Mac não são alterados. A sincronização do iCloud é desativada e permanece desativada até você reativá-la, o que enviará novamente os dados deste Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удаляет все записи Lorvex из вашей учётной записи iCloud — для всех устройств, которые с ней синхронизируются. Локальные данные на этом Mac не затрагиваются. Синхронизация iCloud выключается и остаётся выключенной, пока вы не включите её снова; при этом данные этого Mac будут загружены заново."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex’in tüm kayıtlarını iCloud hesabınızdan siler — bu hesapla eşitlenen tüm aygıtlar için geçerlidir. Bu Mac’teki yerel verilere dokunulmaz. iCloud eşitlemesi kapanır ve siz yeniden açana kadar kapalı kalır; yeniden açtığınızda bu Mac’in verileri yeniden yüklenir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从你的 iCloud 账户中删除所有 Lorvex 记录——对与其同步的所有设备生效。这台 Mac 上的本地数据不受影响。iCloud 同步将关闭并保持关闭，直到你重新启用；重新启用时会重新上传这台 Mac 的数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從你的 iCloud 帳號中刪除所有 Lorvex 記錄——對與其同步的所有裝置生效。這台 Mac 上的本機資料不受影響。iCloud 同步將關閉並保持關閉，直到你重新啟用；重新啟用時會重新上傳這台 Mac 的資料。"
          }
        }
      }
    },
    "settings.cloud_delete.error.failed": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud-Daten konnten nicht vollständig gelöscht werden (%@). Prüfen Sie Ihre Verbindung und versuchen Sie es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t finish deleting iCloud data (%@). Check your connection and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo terminar de eliminar los datos de iCloud (%@). Comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de terminer la suppression des données iCloud (%@). Vérifiez votre connexion et réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile completare l’eliminazione dei dati iCloud (%@). Verifica la connessione e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud データの削除を完了できませんでした（%@）。接続を確認してからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 데이터 삭제를 완료할 수 없습니다(%@). 연결을 확인한 후 다시 시도하십시오."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie można dokończyć usuwania danych iCloud (%@). Sprawdź połączenie i spróbuj ponownie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível concluir a exclusão dos dados do iCloud (%@). Verifique sua conexão e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось завершить удаление данных iCloud (%@). Проверьте подключение и попробуйте ещё раз."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud verilerinin silinmesi tamamlanamadı (%@). Bağlantınızı denetleyip yeniden deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法完成删除 iCloud 数据（%@）。请检查网络连接后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法完成刪除 iCloud 資料（%@）。請檢查網路連線後再試一次。"
          }
        }
      }
    },
    "settings.cloud_delete.error.no_account": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein verwendbarer iCloud-Account. Melden Sie sich bei iCloud an und versuchen Sie es erneut."
          }
        },
        "en": {

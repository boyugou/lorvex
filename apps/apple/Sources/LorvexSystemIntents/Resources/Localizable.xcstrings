    "system.task.provider_event.link.default_dialog": {
      "comment": "Result dialog after linking a task to a calendar event when the provider source is absent; %@ is the task title",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@“ wurde mit dem Kalenderereignis verknüpft."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Linked %@ to the calendar event."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se vinculó «%@» al evento del calendario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« %@ » a été liée à l’événement du calendrier."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@” è stata collegata all’evento del calendario."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」をカレンダーイベントにリンクしました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”을(를) 캘린더 이벤트에 연결했습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Połączono zadanie „%@” z wydarzeniem kalendarza."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@” foi vinculada ao evento do calendário."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Задача «%@» связана с событием календаря."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@” takvim etkinliğine bağlandı."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已将“%@”关联到日历事件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已將「%@」連結到行事曆事件。"
          }
        }
      }
    },
    "system.task.provider_event.link.description": {
      "comment": "Description for the Link Lorvex Task To Provider Event App Intent",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verknüpfe eine Lorvex-Aufgabe mit einem externen Kalenderereignis."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Link a Lorvex task to an external calendar event."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vincula una tarea de Lorvex con un evento de calendario externo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Liez une tâche Lorvex à un événement de calendrier externe."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Collega un'attività Lorvex a un evento di calendario esterno."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvexタスクを外部カレンダーのイベントにリンクします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorvex 작업을 외부 캘린더 이벤트에 연결합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Połącz zadanie Lorvex z zewnętrznym wydarzeniem w kalendarzu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Vincule uma tarefa do Lorvex a um evento de calendário externo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Свяжите задачу Lorvex с внешним событием календаря."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir Lorvex görevini harici bir takvim etkinliğine bağla."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将一个 Lorvex 任务关联到外部日历事件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將一個 Lorvex 任務關聯到外部日曆事件。"
          }
        }
      }
    },

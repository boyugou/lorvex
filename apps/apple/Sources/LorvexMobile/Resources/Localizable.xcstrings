    "memory.delete.confirm.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Speichereintrag und sein Verlauf werden entfernt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The memory entry is removed. This can't be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La entrada de memoria y su historial se eliminarán. Esto no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'entrée de mémoire et son historique seront supprimés. Cette action est irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La voce di memoria e la sua cronologia verranno rimosse. L'azione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メモリ項目とその履歴が削除されます。この操作は取り消せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메모리 항목과 기록이 제거됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wpis pamięci i jego historia zostaną usunięte. Tego nie można cofnąć."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A entrada de memória e seu histórico serão removidos. Isso não pode ser desfeito."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запись памяти и ее история будут удалены. Это нельзя отменить."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bellek girdisi ve geçmişi kaldırılır. Bu işlem geri alınamaz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记忆条目及其历史记录将被移除。此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "記憶項目及其歷史記錄將被移除。此操作無法復原。"
          }
        }
      }
    },

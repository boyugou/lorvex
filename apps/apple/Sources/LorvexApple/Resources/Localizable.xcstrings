    "settings.cloud_sync.mode.live_detail": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Überträgt Datensätze an die private CloudKit-Datenbank und wendet eingehende Remote-Änderungen an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pushes records to the private CloudKit database and applies remote changes on arrival."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía registros a la base de datos privada de CloudKit y aplica los cambios remotos a su llegada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie les enregistrements vers la base de données CloudKit privée et applique les modifications distantes à leur réception."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia i record al database CloudKit privato e applica le modifiche remote al loro arrivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "レコードをプライベート CloudKit データベースにプッシュし、到着したリモートの変更を適用します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "레코드를 비공개 CloudKit 데이터베이스로 푸시하고 도착하는 원격 변경 사항을 적용합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wysyła rekordy do prywatnej bazy danych CloudKit i stosuje zdalne zmiany po ich nadejściu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Envia registros para o banco de dados privado do CloudKit e aplica as alterações remotas quando chegam."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправляет записи в частную базу данных CloudKit и применяет удалённые изменения по мере их поступления."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kayıtları özel CloudKit veritabanına gönderir ve gelen uzak değişiklikleri uygular."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将记录推送到私有 CloudKit 数据库，并在远程变更到达时应用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將記錄推送到私人 CloudKit 資料庫，並在遠端變更到達時套用。"
          }
        }
      }
    },

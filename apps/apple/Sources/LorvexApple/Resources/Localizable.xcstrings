    "settings.cloud_sync.mode.record_plan_detail": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Registriert das CloudKit-Abonnement, führt aber keinen Synchronisierungszyklus aus. Nur zum Debuggen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Registers the CloudKit subscription but runs no sync cycle. For debugging only."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra la suscripción de CloudKit pero no ejecuta ningún ciclo de sincronización. Solo para depuración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistre l'abonnement CloudKit mais n'exécute aucun cycle de synchronisation. À des fins de débogage uniquement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra l'abbonamento CloudKit ma non esegue alcun ciclo di sincronizzazione. Solo per il debug."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CloudKitのサブスクリプションを登録しますが、同期サイクルは実行しません。デバッグ専用です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "CloudKit 구독을 등록하지만 동기화 주기는 실행하지 않습니다. 디버깅 전용입니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rejestruje subskrypcję CloudKit, ale nie uruchamia cyklu synchronizacji. Tylko do debugowania."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra a assinatura do CloudKit, mas não executa nenhum ciclo de sincronização. Apenas para depuração."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Регистрирует подписку CloudKit, но не запускает цикл синхронизации. Только для отладки."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "CloudKit aboneliğini kaydeder ancak hiçbir eşitleme döngüsü çalıştırmaz. Yalnızca hata ayıklama içindir."
          }
        },
        "zh-Hans": {
          "stringUnit": {

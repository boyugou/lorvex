    "settings.sync.delete_cloud.error.busy": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud Sync wird gerade aktualisiert. Versuchen Sie es gleich noch einmal."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud Sync is updating. Try again in a moment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud Sync se está actualizando. Inténtalo de nuevo en un momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud Sync est en cours de mise à jour. Réessayez dans un instant."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud Sync si sta aggiornando. Riprova tra un istante."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud Sync を更新中です。しばらくしてからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud Sync를 업데이트하는 중입니다. 잠시 후 다시 시도하십시오."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud Sync jest aktualizowany. Spróbuj ponownie za chwilę."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Cloud Sync está sendo atualizado. Tente novamente em instantes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud Sync обновляется. Повторите попытку через мгновение."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud Sync güncelleniyor. Birazdan yeniden deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "云同步正在更新。请稍后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "雲端同步正在更新。請稍後再試。"
          }
        }
      }
    },
    "settings.sync.delete_cloud.error.failed": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud-Daten konnten nicht vollständig gelöscht werden (%@). Prüfen Sie Ihre Verbindung und versuchen Sie es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t finish deleting iCloud data (%@). Check your connection and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo terminar de eliminar los datos de iCloud (%@). Comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de terminer la suppression des données iCloud (%@). Vérifiez votre connexion et réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile completare l’eliminazione dei dati iCloud (%@). Verifica la connessione e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud データの削除を完了できませんでした（%@）。接続を確認してからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 데이터 삭제를 완료할 수 없습니다(%@). 연결을 확인한 후 다시 시도하십시오."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie można dokończyć usuwania danych iCloud (%@). Sprawdź połączenie i spróbuj ponownie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível concluir a exclusão dos dados do iCloud (%@). Verifique sua conexão e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось завершить удаление данных iCloud (%@). Проверьте подключение и попробуйте ещё раз."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud verilerinin silinmesi tamamlanamadı (%@). Bağlantınızı denetleyip yeniden deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法完成删除 iCloud 数据（%@）。请检查网络连接后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法完成刪除 iCloud 資料（%@）。請檢查網路連線後再試一次。"
          }
        }
      }
    },
    "settings.sync.delete_cloud.error.no_account": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein verwendbarer iCloud-Account. Melden Sie sich bei iCloud an und versuchen Sie es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No usable iCloud account. Sign in to iCloud and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay ninguna cuenta de iCloud utilizable. Inicia sesión en iCloud e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
